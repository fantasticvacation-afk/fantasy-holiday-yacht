  "case-002.504": { "zh": "图文沉浸，见证每一个精彩瞬间", "en": "图文沉浸，见证每一个精彩瞬间" },
  "case-002.522": { "zh": "核心服务亮点", "en": "核心服务亮点" },
  "case-002.523": { "zh": "差异化能力，打造独一无二的海上旅程", "en": "差异化能力，打造独一无二的海上旅程" },
  "case-002.527": { "zh": "👨‍🍳 米其林主厨团队", "en": "👨‍🍳 米其林主厨团队" },
  "case-002.529": { "zh": "配备米其林二星主厨团队，提供法式、意式、西班牙、希腊等多国料理定制。支持私人宴会、商务接待、主题晚宴等多种场景。", "en": "配备米其林二星主厨团队，提供法式、意式、西班牙、希腊等多国料理Custom。支持私人宴会、商务接待、主题晚宴等多种场景。" },
  "case-002.533": { "zh": "🤿 私人潜水教练", "en": "🤿 私人潜水教练" },
  "case-002.535": { "zh": "配备2名PADI认证潜水教练，提供从入门体验至进阶考证的全流程服务。支持深海探险、水下摄影、沉船探访等特色活动。", "en": "配备2名PADI认证潜水教练，提供从入门体验至进阶考证的全流程服务。支持深海探险、水下摄影、沉船探访等特色活动。" },
  "case-002.539": { "zh": "🌐 多语言礼宾团队", "en": "🌐 多语言礼宾团队" },
  "case-002.541": { "zh": "28人服务团队涵盖英/法/意/德/西/中6种语言，实现全程无障碍沟通。支持岸上活动、商务接待、VIP保护等场景。", "en": "28人服务团队涵盖英/法/意/德/西/中6种语言，实现全程无障碍沟通。支持岸上活动、商务接待、VIP保护等场景。" },
  "case-002.545": { "zh": "🏥 医疗安全保障", "en": "🏥 医疗安全保障" },
  "case-002.547": { "zh": "配备随船全科医生及急救设备，实现常见疾病诊疗与紧急医疗转运。12国24港均有合作医疗机构。", "en": "配备随船全科医生及急救设备，实现常见疾病诊疗与紧急医疗转运。12国24港均有合作医疗机构。" },
  "case-002.551": { "zh": "🛡️ 安保与隐私保护", "en": "🛡️ 安保与隐私保护" },
  "case-002.553": { "zh": "配备专业安保团队，支持VIP保护、隐私隔离、信息加密。商务接待场景可实现独立区域管控。", "en": "配备专业安保团队，支持VIP保护、隐私隔离、信息加密。商务接待场景可实现独立区域管控。" },
  "case-002.557": { "zh": "⚓ 12国靠泊一站式协调", "en": "⚓ 12国靠泊一站式协调" },
  "case-002.559": { "zh": "30天内完成12国24港的靠泊预约、入境办理、物资补给。地中海夏季高峰期仍保持100%靠泊成功率。", "en": "30天内完成12国24港的靠泊预约、入境办理、物资补给。Mediterranean夏季高峰期仍保持100%靠泊成功率。" },
