  "about-culture.169": { "zh": "以顶级工艺标准打造每一艘游艇，追求完美细节。", "en": "以顶级工艺标准打造每一艘Yacht，追求完美细节。" },
  "about-culture.175": { "zh": "客户至上", "en": "客户至上" },
  "about-culture.177": { "zh": "以客户需求为中心，提供个性化定制服务。", "en": "以客户需求为中心，提供个性化Custom服务。" },
  "about-culture.183": { "zh": "创新精神", "en": "创新精神" },
  "about-culture.185": { "zh": "不断探索海洋美学与科技的融合。", "en": "不断探索海洋美学与科技的融合。" },
  "about-culture.192": { "zh": "匠人精神与造船文化", "en": "匠人精神与造船文化" },
  "about-culture.194": { "zh": "在奇幻假期，每一艘游艇都是匠心之作。我们传承欧洲百年造船工艺，结合现代科技与东方美学，为客户打造独一无二的海上艺术品。", "en": "在Fantastic Vacation，每一艘Yacht都是匠心之作。我们传承欧洲百年造船工艺，结合现代科技与东方美学，为客户打造独一无二的海上艺术品。" },
  "about-culture.196": { "zh": "「让每一次航行都成为难忘的体验」是我们对客户的承诺。", "en": "「让每一次航行都成为难忘的体验」是我们对客户的承诺。" },
