  "case-001.536": { "zh": "为中东王室定制的直升机起降与停机坪安全保障方案，通过国际海事直升机安全认证。配备专业空管协调团队，实现与陆地的无缝接驳。", "en": "为Middle East王室Custom的直升机起降与停机坪安全保障方案，通过国际海事直升机安全认证。配备专业空管协调团队，实现与陆地的无缝接驳。" },
  "case-001.540": { "zh": "🛳️ 潜艇车库集成设计", "en": "🛳️ 潜艇车库集成设计" },
  "case-001.542": { "zh": "82米超级游艇配备专用潜艇车库，可搭载小型观光潜艇。支持深海探险与水下摄影活动，配备专业潜水教练团队。", "en": "82米SuperYacht配备专用潜艇车库，可搭载小型观光潜艇。支持深海探险与水下摄影活动，配备专业潜水教练团队。" },
  "case-001.546": { "zh": "🏥 医疗中心国际认证", "en": "🏥 医疗中心国际认证" },
  "case-001.548": { "zh": "独立医疗中心符合国际医疗船标准，配备全科医生、外科手术设备、急救系统。可实现远程会诊与紧急医疗转运。", "en": "独立医疗中心符合国际医疗船标准，配备全科医生、外科手术设备、急救系统。可实现远程会诊与紧急医疗转运。" },
  "case-001.552": { "zh": "🎬 IMAX影院级影音", "en": "🎬 IMAX影院级影音" },
  "case-001.554": { "zh": "定制化IMAX级私人影院，支持3D/4D观影体验。配备杜比全景声系统，可举办私密电影首映与家族观影活动。", "en": "Custom化IMAX级私人影院，支持3D/4D观影体验。配备杜比全景声系统，可举办私密电影首映与家族观影活动。" },
  "case-001.558": { "zh": "🕌 伊斯兰风格内饰", "en": "🕌 伊斯兰风格内饰" },
  "case-001.560": { "zh": "融合东方美学与意式奢华的定制化内饰设计，采用进口大理石、黄金装饰、传统几何纹样。私密性设计符合王室礼仪要求。", "en": "融合东方美学与意式奢华的Custom化内饰设计，采用进口大理石、黄金装饰、传统几何纹样。私密性设计符合王室礼仪要求。" },
  "case-001.564": { "zh": "🛡️ 皇室级安保系统", "en": "🛡️ 皇室级安保系统" },
  "case-001.566": { "zh": "定制化安保系统涵盖雷达监控、反无人机系统、加密通讯、VIP保护团队。通过王室安全部门审核认证。", "en": "Custom化安保系统涵盖雷达监控、反无人机系统、加密通讯、VIP保护团队。通过王室安All门审核认证。" },
  "case-001.576": { "zh": "客户反馈与成果数据", "en": "客户反馈与成果数据" },
  "case-001.577": { "zh": "真实数据，见证服务价值", "en": "真实数据，见证服务价值" },
  "case-001.582": { "zh": "— 王室家族代表，2024年12月", "en": "— 王室家族代表，2024年12月" },
