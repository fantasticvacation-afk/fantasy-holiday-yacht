  "about-structure.221": { "zh": "首席执行官", "en": "首席执行官" },
  "about-structure.223": { "zh": "负责公司整体战略规划与决策，统筹全球业务发展，引领行业创新方向。", "en": "负责公司整体战略规划与决策，统筹全球业务发展，引领行业创新方向。" },
  "about-structure.235": { "zh": "销售部", "en": "销售部" },
  "about-structure.237": { "zh": "负责全球游艇销售、定制方案咨询与客户关系维护。团队拥有丰富的行业经验，为客户提供专业的购艇建议与金融服务方案。", "en": "负责全球Yacht销售、Custom方案咨询与客户关系维护。团队拥有丰富的行业经验，为客户提供专业的购艇建议与金融服务方案。" },
  "about-structure.240": { "zh": "新艇销售与二手艇交易", "en": "新艇销售与二手艇交易" },
  "about-structure.242": { "zh": "定制化需求分析与方案设计", "en": "Custom化需求分析与方案设计" },
  "about-structure.244": { "zh": "金融租赁与保险服务", "en": "金融Charter与保险服务" },
  "about-structure.246": { "zh": "VIP客户专属顾问", "en": "VIP客户专属顾问" },
  "about-structure.256": { "zh": "租赁运营部", "en": "Charter运营部" },
  "about-structure.258": { "zh": "管理全球租赁航线运营，包括船期安排、航线规划、船员管理与客户体验优化，确保每一次航行都完美无瑕。", "en": "管理全球Charter Routes运营，包括船期安排、航线规划、船员管理与客户体验优化，确保每一次航行都完美无瑕。" },
  "about-structure.261": { "zh": "全球热门航线开发与管理", "en": "全球Popular航线开发与管理" },
  "about-structure.263": { "zh": "船期调度与运力优化", "en": "船期调度与运力优化" },
  "about-structure.265": { "zh": "船员培训与服务标准制定", "en": "船员培训与服务标准制定" },
  "about-structure.267": { "zh": "客户行程定制与现场服务", "en": "客户行程Custom与现场服务" },
  "about-structure.277": { "zh": "技术服务部", "en": "技术服务部" },
  "about-structure.279": { "zh": "提供全方位的游艇技术支持，包括日常维保、年度检修、升级改装及紧急救援服务，保障每艘游艇始终处于最佳状态。", "en": "提供全方位的Yacht技术支持，包括日常维保、年度检修、升级改装及紧急救援服务，保障每艘Yacht始终处于最佳状态。" },
  "about-structure.282": { "zh": "预防性维护与定期保养", "en": "预防性维护与定期保养" },
  "about-structure.284": { "zh": "发动机与电子系统维修", "en": "Engine与电子系统维修" },
  "about-structure.286": { "zh": "内饰升级与外观翻新", "en": "内饰升级与外观翻新" },
  "about-structure.288": { "zh": "24/7紧急救援与技术支持", "en": "24/7紧急救援与技术支持" },
  "about-structure.298": { "zh": "市场品牌部", "en": "市场品牌部" },
  "about-structure.300": { "zh": "负责品牌建设、市场推广与公关活动，通过多渠道营销策略提升品牌影响力，打造行业标杆形象。", "en": "负责品牌建设、市场推广与公关活动，通过多渠道营销策略提升品牌影响力，打造行业标杆形象。" },
  "about-structure.303": { "zh": "品牌战略规划与视觉管理", "en": "品牌战略规划与视觉管理" },
  "about-structure.305": { "zh": "数字营销与社交媒体运营", "en": "数字营销与社交媒体运营" },
  "about-structure.307": { "zh": "展会策划与公关活动执行", "en": "展会策划与公关活动执行" },
  "about-structure.309": { "zh": "媒体关系与内容创作", "en": "媒体关系与内容创作" },
  "about-structure.319": { "zh": "财务部", "en": "财务部" },
  "about-structure.321": { "zh": "负责公司财务管理、资金运作、税务筹划与风险控制，为业务发展提供稳健的财务支撑与战略建议。", "en": "负责公司财务管理、资金运作、税务筹划与风险控制，为业务发展提供稳健的财务支撑与战略建议。" },
  "about-structure.324": { "zh": "财务报表编制与分析", "en": "财务报表编制与分析" },
  "about-structure.326": { "zh": "资金管理与融资筹划", "en": "资金管理与融资筹划" },
  "about-structure.328": { "zh": "成本控制与预算管理", "en": "成本控制与预算管理" },
