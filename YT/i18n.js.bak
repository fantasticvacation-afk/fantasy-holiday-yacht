  "cases-custom.291": { "zh": "查看完整案例", "en": "查看完整案例" },
  "cases-custom.299": { "zh": "45米探险游艇「极光号」Aurora", "en": "45米探险Yacht「极光号」Aurora" },
  "cases-custom.301": { "zh": "为环保企业家打造的极地探险游艇，冰级船体认证，可深入南极与阿拉斯加海域。太阳能混合动力系统，续航力达8,000海里，获Green Yacht Award提名。", "en": "为环保企业家打造的极地探险Yacht，冰级船体认证，可深入南极与阿拉斯加海域。太阳能Hybrid系统，续航力达8,000nm，获Green Yacht Award提名。" },
  "cases-custom.304": { "zh": "全案定制", "en": "Full Customization" },
  "cases-custom.306": { "zh": "45m", "en": "45m" },
  "cases-custom.308": { "zh": "极地航线", "en": "极地航线" },
  "cases-custom.310": { "zh": "环保科技", "en": "环保科技" },
  "cases-custom.313": { "zh": "查看完整案例", "en": "查看完整案例" },
  "cases-custom.321": { "zh": "58米商务接待游艇「龙腾号」", "en": "58米商务接待Yacht「龙腾号」" },
  "cases-custom.323": { "zh": "为亚洲企业集团定制的商务接待旗舰，可容纳60人商务活动。配备独立会议室、全景宴会厅、直升机接送平台，年接待高端客户超2,000人次。", "en": "为亚洲企业集团Custom的商务接待Flagship，可容纳60人商务活动。配备独立会议室、全景宴会厅、直升机接送平台，年接待高端客户超2,000人次。" },
  "cases-custom.326": { "zh": "全案定制", "en": "Full Customization" },
  "cases-custom.328": { "zh": "58m", "en": "58m" },
  "cases-custom.330": { "zh": "中国近海", "en": "中国近海" },
