  "case-010.296": { "zh": "核心服务亮点", "en": "核心服务亮点" },
  "case-010.299": { "zh": "🏝️ 原始部落探访", "en": "🏝️ 原始部落探访" },
  "case-010.300": { "zh": "探访瓦努阿图原始部落，宾客可体验原住民文化、传统仪式与手工艺，由当地向导全程陪同。", "en": "探访瓦努阿图原始部落，宾客可体验原住民文化、传统仪式与手工艺，由当地向导全程陪同。" },
  "case-010.302": { "zh": "🤿 世界级潜水", "en": "🤿 世界级潜水" },
  "case-010.303": { "zh": "斐济与瓦努阿图拥有世界顶级潜水点，配备PADI教练与专业潜水装备，探索珊瑚礁与二战沉船。", "en": "斐济与瓦努阿图拥有世界顶级潜水点，配备PADI教练与专业潜水装备，探索珊瑚礁与二战沉船。" },
  "case-010.305": { "zh": "🚁 直升机探险", "en": "🚁 直升机探险" },
  "case-010.306": { "zh": "游艇配备直升机，宾客可空中俯瞰火山、雨林与岛屿，实现陆海空三维探险体验。", "en": "Yacht配备直升机，宾客可空中俯瞰火山、雨林与岛屿，实现陆海空三维探险体验。" },
  "case-010.308": { "zh": "🛶 原始皮划艇", "en": "🛶 原始皮划艇" },
  "case-010.309": { "zh": "配备专业皮划艇团队，宾客可划入红树林与洞穴，探索游艇无法抵达的秘境水道。", "en": "配备专业皮划艇团队，宾客可划入红树林与洞穴，探索Yacht无法抵达的秘境水道。" },
  "case-010.311": { "zh": "🍳 海上米其林", "en": "🍳 海上米其林" },
  "case-010.312": { "zh": "配备米其林星级主厨，结合南太平洋食材与亚洲烹饪技法，提供独特的海上美食体验。", "en": "配备米其林星级主厨，结合南太平洋食材与亚洲烹饪技法，提供独特的海上美食体验。" },
  "case-010.314": { "zh": "📸 专业摄影服务", "en": "📸 专业摄影服务" },
  "case-010.315": { "zh": "配备水下与航拍摄影师，全程记录探险旅程，最终交付精装探险纪录片与相册。", "en": "配备水下与航拍摄影师，全程记录探险旅程，最终交付精装探险纪录片与相册。" },
  "case-010.320": { "zh": "预约同款探险航线", "en": "预约同款探险航线" },
  "case-010.322": { "zh": "我们的专业团队将为您量身打造专属的南太平洋探险巡航方案", "en": "我们的专业团队将为您量身打造专属的南太平洋探险巡航方案" },
