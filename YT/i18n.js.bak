  "case-003.490": { "zh": "中东区域应急协调中心", "en": "Middle East区域应急协调中心" },
  "case-003.492": { "zh": "医疗急救与转运", "en": "医疗急救与转运" },
  "case-003.494": { "zh": "法律与公关危机支持", "en": "法律与公关危机支持" },
  "case-003.496": { "zh": "王室应急出行保障", "en": "王室应急出行保障" },
  "case-003.507": { "zh": "实景与服务细节", "en": "实景与服务细节" },
  "case-003.508": { "zh": "图文沉浸，见证每一个精彩瞬间", "en": "图文沉浸，见证每一个精彩瞬间" },
  "case-003.526": { "zh": "核心服务亮点", "en": "核心服务亮点" },
  "case-003.527": { "zh": "差异化能力，打造行业标杆", "en": "差异化能力，打造行业标杆" },
  "case-003.531": { "zh": "🛡️ 零事故5年记录", "en": "🛡️ 零事故5年记录" },
  "case-003.533": { "zh": "建立全流程安全管理体系，从日常巡检、季度保养到年度检修，实现预防性维护。5年连续零重大事故运营记录，获王室安保部门高度认可。", "en": "建立全流程安全管理体系，从日常巡检、季度保养到年度检修，实现预防性维护。5年连续零重大事故运营记录，获王室安保部门高度认可。" },
  "case-003.537": { "zh": "📊 成本优化18%", "en": "📊 成本优化18%" },
  "case-003.539": { "zh": "通过供应商议价、集中采购、燃油优化等举措，年均运营成本降低18%。5年累计节省超过300万美元。", "en": "通过供应商议价、集中采购、燃油优化等举措，年均运营成本降低18%。5年累计节省超过300万美元。" },
  "case-003.543": { "zh": "👨‍✈️ 86人专业团队", "en": "👨‍✈️ 86人专业团队" },
  "case-003.545": { "zh": "组建86人托管团队（含42名船员），涵盖船长、工程师、服务人员、安保团队。持证率100%，王室服务礼仪培训通过。", "en": "组建86人托管团队（含42名船员），涵盖船长、工程师、服务人员、安保团队。持证率100%，王室服务礼仪培训通过。" },
  "case-003.549": { "zh": "🕌 伊斯兰文化定制", "en": "🕌 伊斯兰文化Custom" },
  "case-003.551": { "zh": "服务细节完全遵循伊斯兰文化要求，包括祈祷室配置、清真餐饮定制、性别分区服务、隐私保护等。获王室家族100%满意度。", "en": "服务细节完全遵循伊斯兰文化要求，包括祈祷室配置、清真餐饮Custom、性别分区服务、隐私保护等。获王室家族100%满意度。" },
  "case-003.555": { "zh": "⚡ 2小时应急响应", "en": "⚡ 2h应急响应" },
  "case-003.557": { "zh": "建立中东区域应急协调中心，实现设备故障2小时内响应、24小时内解决。紧急医疗转运与王室应急出行保障全覆盖。", "en": "建立Middle East区域应急协调中心，实现设备故障2h内响应、24h内解决。紧急医疗转运与王室应急出行保障全覆盖。" },
  "case-003.561": { "zh": "📈 资产保值增值", "en": "📈 资产保值增值" },
  "case-003.563": { "zh": "通过科学保养与合规管理，3艘游艇5年市场估值平均上涨12%，远超行业平均5%水平。", "en": "通过科学保养与合规管理，3艘Yacht5年市场估值平均上涨12%，远超行业平均5%水平。" },
  "case-003.573": { "zh": "客户反馈与成果数据", "en": "客户反馈与成果数据" },
  "case-003.574": { "zh": "真实数据，见证服务价值", "en": "真实数据，见证服务价值" },
  "case-003.579": { "zh": "— 王室家族事务主管，2025年1月", "en": "— 王室家族事务主管，2025年1月" },
