  "case-009.300": { "zh": "租用泰国私人岛屿一日，宾客独享白沙滩与珊瑚礁浮潜，零打扰的私密体验。", "en": "租用泰国私人岛屿一日，宾客独享白沙滩与珊瑚礁浮潜，零打扰的私密体验。" },
