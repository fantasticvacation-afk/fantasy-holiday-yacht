  "charter.845": { "zh": "为高端商务接待、企业年会、客户答谢打造专属海上商务空间，融合奢华与功能性。", "en": "为高端商务接待、企业年会、客户答谢打造专属海上商务空间，融合奢华与功能性。" },
  "charter.850": { "zh": "🎣 专业海钓主题行程", "en": "🎣 专业海钓主题行程" },
  "charter.851": { "zh": "配备专业海钓装备与指导，搭配金牌船长多年渔点经验，从深海拖钓到礁石钓，适合各水平钓客。", "en": "配备专业海钓装备与指导，搭配金牌船长多年渔点经验，从深海拖钓到礁石钓，适合各水平钓客。" },
  "charter.862": { "zh": "租赁全流程解析", "en": "Charter全流程解析" },
  "charter.865": { "zh": "从咨询到启航，我们全程护航——8个标准环节，确保每段旅程安全、顺畅、难忘", "en": "从咨询到启航，我们全程护航——8个标准环节，确保每段旅程安全、顺畅、难忘" },
  "charter.869": { "zh": "01", "en": "01" },
