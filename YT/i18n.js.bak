  "custom.741": { "zh": "载客", "en": "Guests" },
  "custom.743": { "zh": "💡 核心亮点：专业海钓平台 + 鱼探雷达集成 + 活饵舱与鱼获冷藏系统", "en": "💡 核心亮点：专业海钓平台 + 鱼探雷达集成 + 活饵舱与鱼获冷藏系统" },
  "custom.749": { "zh": "Case 006 · 远征系列", "en": "Case 006 · Expedition Series" },
  "custom.751": { "zh": "远征62M 地中海派对版", "en": "远征62M Mediterranean派对版" },
  "custom.753": { "zh": "社交名流的移动派对城堡。主甲板设开放式DJ台与舞池区域，飞桥甲板配置户外酒吧与烧烤区。水下灯光系统支持16色场景切换，配合B&amp;O环绕音响打造夜店级娱乐体验。侧甲板可展开为浮动观景平台，圣托里尼日落时分绝美。", "en": "社交名流的移动派对城堡。主甲板设开放式DJ台与舞池区域，飞桥甲板配置户外酒吧与烧烤区。水下灯光系统支持16色场景切换，配合B&amp;O环绕音响打造夜店级娱乐体验。侧甲板可展开为浮动观景平台，圣托里尼日落时分绝美。" },
  "custom.755": { "zh": "62M", "en": "62M" },
