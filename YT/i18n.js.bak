  "custom.797": { "zh": "32", "en": "32" },
  "custom.798": { "zh": "载客", "en": "Guests" },
  "custom.800": { "zh": "💡 核心亮点：海滩俱乐部后甲板 + 全套水上玩具库 + 热带藤编自然内饰", "en": "💡 核心亮点：海滩俱乐部后甲板 + 全套水上玩具库 + 热带藤编自然内饰" },
  "custom.806": { "zh": "Case 009 · 远征系列", "en": "Case 009 · Expedition Series" },
  "custom.808": { "zh": "远征48M 东南亚岛屿版", "en": "远征48M Southeast Asia岛屿版" },
  "custom.810": { "zh": "探索安达曼海与南海群岛的理想伴侣。浅吃水设计可深入热带岛屿隐秘海湾，宽大飞桥适合观赏日落与星空露营。内饰融合巴厘岛热带风情与现代简约，大量使用当地手工编织品与天然石材。配备潜水装备舱与皮划艇存放区。", "en": "探索安达曼海与南海群岛的理想伴侣。浅Draft设计可深入热带岛屿隐秘海湾，宽大飞桥适合观赏日落与星空露营。内饰融合巴厘岛热带风情与现代简约，大量使用当地手工编织品与天然石材。配备潜水装备舱与皮划艇存放区。" },
  "custom.812": { "zh": "48M", "en": "48M" },
