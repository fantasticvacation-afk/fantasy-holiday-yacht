  "case-004.373": { "zh": "极地低温环境下的设备稳定性与人员安全", "en": "极地低温环境下的设备稳定性与人员安全" },
  "case-004.375": { "zh": "科研设备与游艇平台的接口标准化设计", "en": "科研设备与Yacht平台的接口标准化设计" },
  "case-004.377": { "zh": "南极与阿拉斯加航线的合规准入办理", "en": "南极与阿拉斯加航线的合规准入办理" },
  "case-004.379": { "zh": "极地科考活动的风险管理与应急预案", "en": "极地科考活动的风险管理与应急预案" },
