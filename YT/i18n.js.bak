  "custom.779": { "zh": "载客", "en": "Guests" },
  "custom.781": { "zh": "💡 核心亮点：破冰船体 + 恒温样本实验室 + ROV起重架 + 模块化居住区", "en": "💡 核心亮点：破冰船体 + 恒温样本实验室 + ROV起重架 + 模块化居住区" },
  "custom.787": { "zh": "Case 008 · 君临系列", "en": "Case 008 · Monarch Series" },
  "custom.789": { "zh": "君临95M 加勒比巡航版", "en": "君临95M 加勒比巡航版" },
  "custom.791": { "zh": "专为加勒比海全年巡航设计。开放式海滩俱乐部风格后甲板，可直接跳入加勒比海的透明海水。水上玩具库包含Jet Ski、Seabob、Flyboard等全套装备。热带风情内饰以天然藤编与白色橡木为主材，营造轻松惬意的岛屿度假氛围。", "en": "专为Caribbean全年巡航设计。开放式海滩俱乐部风格后甲板，可直接跳入Caribbean的透明海水。水上玩具库包含Jet Ski、Seabob、Flyboard等全套装备。热带风情内饰以天然藤编与白色橡木为主材，营造轻松惬意的岛屿度假氛围。" },
  "custom.793": { "zh": "95M", "en": "95M" },
