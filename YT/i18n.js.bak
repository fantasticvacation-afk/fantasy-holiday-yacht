  "case-005.488": { "zh": "120人海上活动保险配置", "en": "120人海上活动保险配置" },
  "case-005.490": { "zh": "加勒比海航行日志归档", "en": "Caribbean航行日志归档" },
  "case-005.492": { "zh": "婚礼行业奖项申报支持", "en": "婚礼行业奖项申报支持" },
  "case-005.503": { "zh": "实景与服务细节", "en": "实景与服务细节" },
  "case-005.504": { "zh": "图文沉浸，见证每一个精彩瞬间", "en": "图文沉浸，见证每一个精彩瞬间" },
  "case-005.522": { "zh": "核心服务亮点", "en": "核心服务亮点" },
  "case-005.523": { "zh": "差异化能力，打造独一无二的海上婚礼传奇", "en": "差异化能力，打造独一无二的海上婚礼传奇" },
  "case-005.527": { "zh": "🚁 直升机空中婚礼", "en": "🚁 直升机空中婚礼" },
  "case-005.529": { "zh": "新娘搭乘直升机从空中入场，在85米超级游艇的直升机平台着陆。全程配备专业空管协调团队，实现安全与浪漫的完美结合。", "en": "新娘搭乘直升机从空中入场，在85米SuperYacht的直升机平台着陆。全程配备专业空管协调团队，实现安全与浪漫的完美结合。" },
  "case-005.533": { "zh": "🎎 中式仪式场地定制", "en": "🎎 中式仪式场地Custom" },
  "case-005.535": { "zh": "游艇甲板临时搭建中式婚礼仪式场地，配备敬茶台、拜堂区、喜字装饰。完全遵循中式婚礼传统，实现海上与传统的融合。", "en": "Yacht甲板临时搭建中式婚礼仪式场地，配备敬茶台、拜堂区、喜字装饰。完全遵循中式婚礼传统，实现海上与传统的融合。" },
  "case-005.539": { "zh": "🤿 水下派对空间", "en": "🤿 水下派对空间" },
  "case-005.541": { "zh": "配备专业水下派对平台，宾客可通过浮潜或水肺潜水参与水下派对。配备水下摄影团队，记录每一位宾客的水下精彩瞬间。", "en": "配备专业水下派对平台，宾客可通过浮潜或水肺潜水参与水下派对。配备水下摄影团队，记录每一位宾客的水下精彩瞬间。" },
  "case-005.545": { "zh": "👨‍🍳 米其林婚宴定制", "en": "👨‍🍳 米其林婚宴Custom" },
  "case-005.547": { "zh": "配备米其林二星主厨团队，提供中式婚宴（龙凤呈祥、鸿运当头等）与西式自助双线菜单。支持120人同时用餐。", "en": "配备米其林二星主厨团队，提供中式婚宴（龙凤呈祥、鸿运当头等）与西式自助双线菜单。支持120人同时用餐。" },
  "case-005.551": { "zh": "📹 全程直播与纪录片", "en": "📹 全程直播与纪录片" },
  "case-005.553": { "zh": "配备专业摄影摄像团队，全程记录婚礼每个瞬间。支持实时直播，让无法到场的亲友远程参与。最终交付90分钟婚礼纪录片。", "en": "配备专业摄影摄像团队，全程记录婚礼每个瞬间。支持实时直播，让无法到场的亲友远程参与。最终交付90分钟婚礼纪录片。" },
  "case-005.557": { "zh": "🏆 年度最佳海上婚礼", "en": "🏆 年度最佳海上婚礼" },
  "case-005.559": { "zh": "凭借创新的中西融合婚礼方案与零安全事故的完美执行，荣获Wedding Industry Awards 2024年度最佳海上婚礼大奖。", "en": "凭借创新的中西融合婚礼方案与零安全事故的完美执行，荣获Wedding Industry Awards 2024年度最佳海上婚礼大奖。" },
  "case-005.569": { "zh": "客户反馈与成果数据", "en": "客户反馈与成果数据" },
  "case-005.570": { "zh": "真实数据，见证服务价值", "en": "真实数据，见证服务价值" },
  "case-005.575": { "zh": "— 家族长辈，2024年12月", "en": "— 家族长辈，2024年12月" },
