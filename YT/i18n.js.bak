  "case-007.296": { "zh": "核心服务亮点", "en": "核心服务亮点" },
  "case-007.299": { "zh": "🎨 全新内饰设计", "en": "🎨 全新内饰设计" },
  "case-007.300": { "zh": "邀请意大利顶级设计工作室，完成800㎡内饰全面焕新，采用缅甸黑木、意大利大理石等顶级材料。", "en": "邀请意大利顶级设计工作室，完成800㎡内饰全面焕新，采用缅甸黑木、意大利大理石等顶级材料。" },
  "case-007.302": { "zh": "⚡ 动力系统升级", "en": "⚡ 动力系统升级" },
  "case-007.303": { "zh": "更换最新MTU 16V 4000 M96L发动机，配合推进系统优化，最大航速提升20%，燃油效率提升15%。", "en": "更换最新MTU 16V 4000 M96LEngine，配合推进系统优化，最大Speed提升20%，燃油效率提升15%。" },
  "case-007.305": { "zh": "📱 智能系统安装", "en": "📱 智能系统安装" },
  "case-007.306": { "zh": "部署全船智能控制系统，实现舱室温控、灯光、影音、导航一键操控，支持语音与远程APP控制。", "en": "部署全船智能控制系统，实现舱室温控、灯光、影音、导航一键操控，支持语音与远程APP控制。" },
  "case-007.308": { "zh": "🏊 甲板设施焕新", "en": "🏊 甲板设施焕新" },
  "case-007.309": { "zh": "飞桥甲板增设无边泳池与日光浴区，主甲板增设户外影院系统，实现酒店级度假体验。", "en": "飞桥甲板增设无边泳池与日光浴区，主甲板增设户外影院系统，实现酒店级度假体验。" },
  "case-007.311": { "zh": "🔧 船体结构维护", "en": "🔧 船体结构维护" },
  "case-007.312": { "zh": "完成钢制船体全面检测与防腐处理，更换抗老化涂层，预计延长船体寿命15年以上。", "en": "完成钢制船体全面检测与防腐处理，更换抗老化涂层，预计延长船体寿命15年以上。" },
  "case-007.314": { "zh": "🏆 年度最佳改装", "en": "🏆 年度最佳改装" },
  "case-007.315": { "zh": "凭借创新的设计方案与精湛的施工工艺，荣获Superyacht Refit Awards 2024年度最佳改装项目。", "en": "凭借创新的设计方案与精湛的施工工艺，荣获Superyacht Refit Awards 2024年度最佳改装项目。" },
