  "charter.993": { "zh": "全程航行保障", "en": "全程航行保障" },
  "charter.995": { "zh": "全面航海保险覆盖、卫星通信、应急医疗设备、海上救援协调，港口费与燃料费全含，无隐性消费。", "en": "全面航海保险覆盖、卫星通信、应急医疗设备、海上救援协调，港口费与燃料费全含，无隐性消费。" },
