  "management.646": { "zh": "精英专业团队", "en": "精英专业团队" },
  "management.648": { "zh": "持证船长、注册轮机工程师、海事法律顾问、保险精算师组成的复合型专家团队，平均从业经验超过12年。", "en": "持证船长、注册轮机工程师、海事法律顾问、保险精算师组成的复合型专家团队，平均从业经验超过12年。" },
  "management.654": { "zh": "智能数字管理", "en": "智能数字管理" },
  "management.656": { "zh": "自主研发船东专属APP，实时查看游艇位置、航行轨迹、设备状态、财务报表，一切尽在掌握。", "en": "自主研发船东专属APP，实时查看Yacht位置、航行轨迹、设备状态、财务报表，一切尽在掌握。" },
  "management.662": { "zh": "全球服务网络", "en": "全球服务网络" },
  "management.664": { "zh": "在亚太、地中海、加勒比海三大核心区域设有服务基地，覆盖全球30+主要游艇停靠港。", "en": "在亚太、Mediterranean、Caribbean三大核心区域设有服务基地，覆盖全球30+主要Yacht停靠港。" },
  "management.670": { "zh": "成本优化能力", "en": "成本优化能力" },
  "management.672": { "zh": "依托集团级采购议价能力和精细化运营管理，帮助船东平均降低15%-20%的年度持有成本。", "en": "依托集团级采购议价能力和精细化运营管理，帮助船东平均降低15%-20%的年度持有成本。" },
  "management.683": { "zh": "资质认证与服务保障", "en": "资质认证与服务保障" },
  "management.685": { "zh": "权威认证背书，多重保障护航", "en": "权威认证背书，多重保障护航" },
