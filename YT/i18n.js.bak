  "about-history.134": { "zh": "EN", "en": "EN" },
  "about-history.155": { "zh": "发展历程", "en": "History" },
  "about-history.157": { "zh": "见证中国高端游艇行业的崛起与成长", "en": "见证中国高端Yacht行业的崛起与成长" },
  "about-history.162": { "zh": "2026", "en": "2026" },
  "about-history.163": { "zh": "亚太区总部在香港正式成立，全球服务网络扩展至50+港口。与Aman、Four Seasons等顶级酒店集团达成战略合作，进军海上文旅板块。完成B轮融资后估值突破20亿人民币。", "en": "亚太区总部在香港正式成立，全球服务网络扩展至50+港口。与Aman、Four Seasons等顶级酒店集团达成战略合作，进军海上文旅板块。完成B轮融资后估值突破20亿人民币。" },
  "about-history.165": { "zh": "2025", "en": "2025" },
  "about-history.166": { "zh": "与荷兰Feadship签署技术合作协议，获得先进造船工艺授权。年度交付量突破100艘，营收突破10亿人民币。获评「亚洲最佳游艇服务提供商」荣誉。", "en": "与荷兰Feadship签署技术合作协议，获得先进造船工艺授权。年度交付量突破100艘，营收突破10亿人民币。获评「亚洲最佳Yacht服务提供商」荣誉。" },
  "about-history.168": { "zh": "2024", "en": "2024" },
  "about-history.169": { "zh": "完成A轮融资1.2亿元。与意大利Ferretti集团达成中国区独家战略合作。交付首艘国产超大型游艇「君临88米」，填补国内空白。", "en": "完成A轮融资1.2亿元。与意大利Ferretti集团达成中国区独家战略合作。交付首艘国产超大型Yacht「君临88米」，填补国内空白。" },
  "about-history.171": { "zh": "2023", "en": "2023" },
  "about-history.172": { "zh": "奇幻假期实业有限公司在上海成立。首款定制游艇交付，客户覆盖中国顶级富豪圈层。创始人陈瀚宇曾任职LVMH集团游艇事业部。", "en": "Fantastic Vacation实业有限公司在上海成立。首款CustomYacht交付，客户覆盖中国顶级富豪圈层。创始人陈瀚宇曾任职LVMH集团Yacht事业部。" },
  "about-history.177": { "zh": "成长数据", "en": "成长数据" },
