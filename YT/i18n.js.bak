  "case-004.342": { "zh": "📋 项目背景", "en": "📋 项目背景" },
  "case-004.344": { "zh": "客户为知名环保企业家，长期关注气候变化与极地生态保护。需打造一艘既可满足个人极地探险需求，又能支持科研团队海上科考作业的专业探险游艇。", "en": "客户为知名环保企业家，长期关注气候变化与极地生态保护。需打造一艘既可满足个人极地探险需求，又能支持科研团队海上科考作业的专业探险Yacht。" },
  "case-004.348": { "zh": "🎯 核心诉求", "en": "🎯 核心诉求" },
  "case-004.351": { "zh": "冰级船体认证，可安全深入南极与阿拉斯加海域", "en": "冰级船体认证，可安全深入南极与阿拉斯加海域" },
  "case-004.353": { "zh": "太阳能混合动力系统，最小化碳排放足迹", "en": "太阳能Hybrid系统，最小化碳排放足迹" },
  "case-004.355": { "zh": "续航力需达8,000海里以上，支持长航线科考", "en": "续航力需达8,000nm以上，支持长航线科考" },
  "case-004.357": { "zh": "配备专业科研设备接口，支持水下取样与数据采集", "en": "配备专业科研设备接口，支持水下取样与数据采集" },
  "case-004.359": { "zh": "客舱可容纳12位宾客及8名科研人员", "en": "客舱可容纳12位宾客及8名科研人员" },
  "case-004.361": { "zh": "卫星通讯系统，实现极地远程数据传输", "en": "卫星通讯系统，实现极地远程数据传输" },
  "case-004.363": { "zh": "直升机停机坪，支持冰上科考与紧急救援", "en": "直升机停机坪，支持冰上科考与紧急救援" },
