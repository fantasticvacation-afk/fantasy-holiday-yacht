  "case-001.342": { "zh": "📋 项目背景", "en": "📋 项目背景" },
  "case-001.344": { "zh": "客户为中东王室成员，需打造一艘集私人度假、家族聚会与高端公务接待于一体的超级游艇。对游艇的私密性、奢华度、功能多样性及跨海域航行能力均有极高要求。", "en": "客户为Middle East王室成员，需打造一艘集私人度假、家族聚会与高端公务接待于一体的SuperYacht。对Yacht的私密性、奢华度、功能多样性及跨海域航行能力均有极高要求。" },
  "case-001.348": { "zh": "🎯 核心诉求", "en": "🎯 核心诉求" },
  "case-001.351": { "zh": "可容纳16位宾客的奢华客舱，每间均需独立卫浴、观景阳台", "en": "可容纳16位宾客的奢华客舱，每间均需独立卫浴、观景阳台" },
  "case-001.353": { "zh": "搭载直升机起降平台，实现与陆地无缝接驳", "en": "搭载直升机起降平台，实现与陆地无缝接驳" },
  "case-001.355": { "zh": "配备潜艇车库，支持深海探险活动", "en": "配备潜艇车库，支持深海探险活动" },
  "case-001.357": { "zh": "独立医疗中心，符合国际医疗船标准", "en": "独立医疗中心，符合国际医疗船标准" },
  "case-001.359": { "zh": "IMAX影院级影音系统，满足高端娱乐需求", "en": "IMAX影院级影音系统，满足高端娱乐需求" },
  "case-001.361": { "zh": "冰级船体认证，具备跨海域远航能力", "en": "冰级船体认证，具备跨海域远航能力" },
  "case-001.363": { "zh": "伊斯兰风格内饰，融合东方美学与意式奢华", "en": "伊斯兰风格内饰，融合东方美学与意式奢华" },
