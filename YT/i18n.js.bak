  "faq.250": { "zh": "常见问题", "en": "常见问题" },
  "faq.252": { "zh": "奇幻假期fantastic.vacation — 您的疑问，我们为您解答", "en": "Fantastic Vacationfantastic.vacation — 您的疑问，我们为您解答" },
  "faq.257": { "zh": "全部问题", "en": "All问题" },
  "faq.259": { "zh": "游艇定制", "en": "YachtCustom" },
  "faq.261": { "zh": "租赁航线", "en": "Charter Routes" },
  "faq.263": { "zh": "托管维保", "en": "Management & Maintenance" },
  "faq.265": { "zh": "其他问题", "en": "其他问题" },
  "faq.269": { "zh": "定制一艘游艇需要多长时间？", "en": "Custom一艘Yacht需要多长时间？" },
  "faq.271": { "zh": "定制周期根据游艇尺寸和复杂度不同而异。一般30-45米游艇需要12-18个月，50-70米需要18-24个月，80米以上超级游艇需要24-36个月。我们会根据您的需求制定详细的项目时间表。", "en": "Custom周期根据YachtSize和复杂度不同而异。一般30-45米Yacht需要12-18个月，50-70米需要18-24个月，80米以上SuperYacht需要24-36个月。我们会根据您的需求制定详细的项目时间表。" },
  "faq.273": { "zh": "定制游艇的价格范围是多少？", "en": "CustomYacht的Price范围是多少？" },
  "faq.275": { "zh": "定制游艇价格因尺寸、配置、材料而异。30米级约1.5-3亿元人民币，50米级约3-8亿元，80米级超级游艇可达10-30亿元。我们提供市价1/10的极致性价比，同时确保顶级品质。", "en": "CustomYachtPrice因Size、配置、材料而异。30米级约1.5-3亿元人民币，50米级约3-8亿元，80米级SuperYacht可达10-30亿元。我们提供市价1/10的极致性价比，同时确保顶级品质。" },
  "faq.277": { "zh": "租赁航线最低几天起订？", "en": "Charter Routes最低几天起订？" },
  "faq.279": { "zh": "最低租赁天数为3天2夜。短途航线（3-7天）适合周末度假，中途航线（7-14天）适合深度体验，长线航线（14天以上）适合环球探险。", "en": "最低Charter天数为3天2夜。短途航线（3-7天）适合周末度假，中途航线（7-14 Days）适合深度体验，长线航线（14天以上）适合环球探险。" },
  "faq.281": { "zh": "租赁费用包含哪些服务？", "en": "Charter费用包含哪些服务？" },
  "faq.283": { "zh": "租赁费用包含：游艇使用、专业船员团队、燃油、港口停泊费、餐饮服务、活动策划、保险。不包含：机票、岸上消费、特别定制服务。", "en": "Charter费用包含：Yacht使用、专业船员团队、燃油、港口停泊费、餐饮服务、活动策划、保险。不包含：机票、岸上消费、特别Custom服务。" },
  "faq.285": { "zh": "托管服务包含哪些内容？", "en": "托管服务包含哪些内容？" },
  "faq.287": { "zh": "全托管服务包含：日常运营管理、船员招聘培训、定期保养维护、海事合规年检、保险理赔协助、财务报表管理、资产保值规划。", "en": "全托管服务包含：日常运营管理、船员招聘培训、定期保养维护、海事合规年检、保险理赔协助、财务报表管理、资产保值规划。" },
  "faq.289": { "zh": "托管费用如何计算？", "en": "托管费用如何计算？" },
  "faq.291": { "zh": "托管费用根据游艇尺寸和服务等级计算。基础托管约年费用的8-10%，全托管约15-20%，至尊托管约25-30%。具体费用请咨询客服。", "en": "托管费用根据YachtSize和服务等级计算。基础托管约年费用的8-10%，全托管约15-20%，至尊托管约25-30%。具体费用请咨询客服。" },
  "faq.293": { "zh": "如何保障海上安全？", "en": "如何保障海上安全？" },
  "faq.295": { "zh": "所有游艇配备国际认证安全设备，船员均持国际海事证书，全程配备医疗团队。近5年零安全事故记录，并购买全球顶级保险。", "en": "所有Yacht配备国际认证安全设备，船员均持国际海事证书，全程配备医疗团队。近5年零安全事故记录，并购买全球顶级保险。" },
  "faq.297": { "zh": "如何预约咨询服务？", "en": "如何预约咨询服务？" },
