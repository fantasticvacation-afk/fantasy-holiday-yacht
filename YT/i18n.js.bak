  "custom.724": { "zh": "💡 核心亮点：家庭友好设计 + 儿童水上乐园 + 米其林厨房 + 120㎡主人套房", "en": "💡 核心亮点：家庭友好设计 + 儿童水上乐园 + 米其林厨房 + 120㎡主人套房" },
  "custom.730": { "zh": "Case 005 · 日间系列", "en": "Case 005 · Day Cruiser Series" },
  "custom.732": { "zh": "日间15M 运动海钓版", "en": "日间15M 运动海钓版" },
  "custom.734": { "zh": "海钓发烧友的梦想战艇。尾部设专业海钓平台，配备活饵舱、鱼获冷藏柜与专业钓具收纳系统。驾驶台集成鱼探雷达与海底地形图系统。侧甲板可展开为稳定浮台，深海拖钓时提供额外作业空间。", "en": "海钓发烧友的梦想战艇。尾部设专业海钓平台，配备活饵舱、鱼获冷藏柜与专业钓具收纳系统。驾驶台集成鱼探雷达与海底地形图系统。侧甲板可展开为稳定浮台，深海拖钓时提供额外作业空间。" },
