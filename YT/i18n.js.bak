  "partner-cases.342": { "zh": "Sotheby's 游艇艺术展合作", "en": "Sotheby's Yacht艺术展合作" },
  "partner-cases.344": { "zh": "与苏富比合作策划全球首场「海上艺术展」——在88米超级游艇上展示估值超$5000万的当代艺术品。活动吸引来自全球的80余位藏家参与，开创了游艇+艺术跨界合作的先河。", "en": "与苏富比合作策划全球首场「海上艺术展」——在88米SuperYacht上展示估值超$5000万的当代艺术品。活动吸引来自全球的80余位藏家参与，开创了Yacht+艺术跨界合作的先河。" },
  "partner-cases.346": { "zh": "📍 摩纳哥", "en": "📍 摩纳哥" },
