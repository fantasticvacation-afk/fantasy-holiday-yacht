  "charter.907": { "zh": "行程结束后交付全部照片与视频，会员积分累积，下次出行享专属优惠", "en": "行程结束后交付All照片与视频，会员积分累积，下次出行享专属优惠" },
  "charter.917": { "zh": "服务包含与增值权益", "en": "服务包含与增值权益" },
  "charter.920": { "zh": "我们为每条航线配备完整的高端服务体系，确保您在海上享受与陆地上同等甚至更优越的体验", "en": "我们为每条航线配备完整的高端服务体系，确保您在海上享受与陆地上同等甚至更优越的体验" },
  "charter.928": { "zh": "精配游艇", "en": "精配Yacht" },
  "charter.930": { "zh": "根据航线特点匹配最适合的船型，出发前全面检测与清洁，确保航行安全与舒适体验。", "en": "根据航线特点匹配最适合的船型，出发前全面检测与清洁，确保航行安全与舒适体验。" },
