  "charter.967": { "zh": "水上活动全含", "en": "水上活动全含" },
  "charter.969": { "zh": "滑水、浮潜、深潜、桨板、水上摩托、海钓装备全部配齐，专业教练指导，安全设备齐全。", "en": "滑水、浮潜、深潜、桨板、水上摩托、海钓装备All配齐，专业教练指导，安全设备齐全。" },
  "charter.971": { "zh": "浮潜", "en": "浮潜" },
