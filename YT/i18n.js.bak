  "custom.683": { "zh": "20", "en": "20" },
  "custom.684": { "zh": "载客", "en": "Guests" },
  "custom.686": { "zh": "💡 核心亮点：冰区航行A级认证 + 科考实验室 + 北欧极简暖调内饰", "en": "💡 核心亮点：冰区航行A级认证 + 科考实验室 + Northern Europe极简暖调内饰" },
  "custom.692": { "zh": "Case 003 · 飞桥系列", "en": "Case 003 · Flybridge Series" },
  "custom.694": { "zh": "飞桥38M 商务休闲版", "en": "飞桥38M 商务休闲版" },
  "custom.696": { "zh": "企业CEO的移动会客厅。飞桥甲板设半开放式商务洽谈区，主厅配备视频会议系统与加密通讯设备。下层甲板设4间VIP套房，每间均带独立办公角。飞桥日光浴区可转换为鸡尾酒会场地，容纳30人社交活动。", "en": "企业CEO的移动会客厅。飞桥甲板设半开放式商务洽谈区，主厅配备视频会议系统与加密通讯设备。下层甲板设4间VIP套房，每间均带独立办公角。飞桥日光浴区可转换为鸡尾酒会场地，容纳30人社交活动。" },
