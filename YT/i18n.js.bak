  "charter.973": { "zh": "教练", "en": "教练" },
  "charter.980": { "zh": "岸上行程预订", "en": "岸上行程预订" },
  "charter.982": { "zh": "停靠港口餐厅、米其林用餐、景点门票、当地向导全程代订，无缝衔接陆地体验与海上时光。", "en": "停靠港口餐厅、米其林用餐、景点门票、当地向导全程代订，无缝衔接陆地体验与海上时光。" },
