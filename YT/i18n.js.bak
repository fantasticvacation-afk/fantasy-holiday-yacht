  "partner-process.251": { "zh": "全球合作", "en": "Global Partnership" },
  "partner-process.254": { "zh": "🤝 合作流程", "en": "🤝 合作流程" },
  "partner-process.256": { "zh": "五步标准化合作流程 · 从意向到落地 · 全程专属服务", "en": "五步标准化合作流程 · 从意向到落地 · 全程专属服务" },
  "partner-process.260": { "zh": "标准化合作流程", "en": "标准化合作流程" },
  "partner-process.261": { "zh": "我们建立了完善的五步合作服务体系，确保每个合作项目从初次接触到最终落地都经过严格的质量管控与专业服务。", "en": "我们建立了完善的五步合作服务体系，确保每个合作项目从初次接触到最终落地都经过严格的质量管控与专业服务。" },
  "partner-process.264": { "zh": "01", "en": "01" },
  "partner-process.266": { "zh": "📋 意向提交", "en": "📋 意向Submit" },
  "partner-process.267": { "zh": "1-3个工作日", "en": "1-3个工作日" },
  "partner-process.269": { "zh": "通过官网表单、邮件或电话提交合作意向，我们的商务团队将在24小时内与您取得联系。", "en": "通过官网表单、邮件或TelSubmit合作意向，我们的商务团队将在24h内与您取得联系。" },
  "partner-process.272": { "zh": "填写《合作意向登记表》— 合作类型、目标区域、预期规模", "en": "填写《合作意向登记表》— 合作类型、目标区域、预期规模" },
  "partner-process.274": { "zh": "提供企业资质文件 — 营业执照、行业资质、过往业绩", "en": "提供企业资质文件 — 营业执照、行业资质、过往业绩" },
  "partner-process.276": { "zh": "初步沟通需求 — 我们安排专属客户经理一对一对接", "en": "初步沟通需求 — 我们安排专属客户经理一对一对接" },
  "partner-process.279": { "zh": "02", "en": "02" },
  "partner-process.281": { "zh": "🔍 资质评估与需求分析", "en": "🔍 资质评估与需求分析" },
  "partner-process.282": { "zh": "3-5个工作日", "en": "3-5个工作日" },
  "partner-process.284": { "zh": "我们的专业团队对合作伙伴进行全面评估，包括企业实力、市场资源、品牌契合度等多维度分析。", "en": "我们的专业团队对合作伙伴进行全面评估，包括企业实力、市场资源、品牌契合度等多维度分析。" },
  "partner-process.287": { "zh": "企业背景调查 — 财务状况、行业口碑、合规记录", "en": "企业背景调查 — 财务状况、行业口碑、合规记录" },
  "partner-process.289": { "zh": "市场资源评估 — 客户群体、渠道网络、区域覆盖能力", "en": "市场资源评估 — 客户群体、渠道网络、区域覆盖能力" },
  "partner-process.291": { "zh": "需求匹配分析 — 双方资源互补性、合作可行性报告", "en": "需求匹配分析 — 双方资源互补性、合作可行性报告" },
  "partner-process.293": { "zh": "初步合作方案框架 — 合作模式、权责划分、收益分配", "en": "初步合作方案框架 — 合作模式、权责划分、收益分配" },
  "partner-process.296": { "zh": "03", "en": "03" },
  "partner-process.298": { "zh": "💡 方案定制与商务谈判", "en": "💡 方案Custom与商务谈判" },
  "partner-process.299": { "zh": "5-10个工作日", "en": "5-10个工作日" },
  "partner-process.301": { "zh": "基于评估结果，双方深入沟通，制定量身定制的合作方案。法务团队全程参与，确保协议条款清晰公正。", "en": "基于评估结果，双方深入沟通，制定量身Custom的合作方案。法务团队全程参与，确保协议条款清晰公正。" },
  "partner-process.304": { "zh": "详细合作方案 — 包含具体KPI、服务标准、质量要求", "en": "详细合作方案 — 包含具体KPI、服务标准、质量要求" },
  "partner-process.306": { "zh": "商务条款谈判 — 授权范围、定价策略、售后责任", "en": "商务条款谈判 — 授权范围、定价策略、售后责任" },
  "partner-process.308": { "zh": "法律协议起草 — 合作协议、保密协议、知识产权条款", "en": "法律协议起草 — 合作协议、保密协议、知识产权条款" },
  "partner-process.310": { "zh": "高层最终确认 — 双方管理层审批签署", "en": "高层最终确认 — 双方管理层审批签署" },
  "partner-process.313": { "zh": "04", "en": "04" },
  "partner-process.315": { "zh": "📝 签约启动与系统对接", "en": "📝 签约启动与系统对接" },
  "partner-process.316": { "zh": "5-15个工作日", "en": "5-15个工作日" },
  "partner-process.318": { "zh": "正式签约后，启动系统集成与团队培训工作，确保合作业务能够快速上线运营。", "en": "正式签约后，启动系统集成与团队培训工作，确保合作业务能够快速上线运营。" },
  "partner-process.321": { "zh": "签署战略合作协议（SHA）", "en": "签署战略合作协议（SHA）" },
  "partner-process.323": { "zh": "系统API/数据接口对接（如涉及技术合作）", "en": "系统API/数据接口对接（如涉及技术合作）" },
  "partner-process.325": { "zh": "团队培训 — 产品知识、服务标准、操作流程认证", "en": "团队培训 — 产品知识、服务标准、操作流程认证" },
  "partner-process.327": { "zh": "营销物料支持 — 品牌授权、宣传资料、联合推广计划", "en": "营销物料支持 — 品牌授权、宣传资料、联合推广计划" },
  "partner-process.329": { "zh": "试运行期 — 30天试运营，全程跟踪支持", "en": "试运行期 — 30天试运营，全程跟踪支持" },
  "partner-process.332": { "zh": "05", "en": "05" },
  "partner-process.334": { "zh": "🚀 项目落地与持续优化", "en": "🚀 项目落地与持续优化" },
  "partner-process.335": { "zh": "长期", "en": "长期" },
  "partner-process.337": { "zh": "合作项目正式启动后，我们提供持续的运营支持与优化服务，确保合作长期稳定发展。", "en": "合作项目正式启动后，我们提供持续的运营支持与优化服务，确保合作长期稳定发展。" },
  "partner-process.340": { "zh": "月度经营数据分析与优化建议", "en": "月度经营数据分析与优化建议" },
  "partner-process.342": { "zh": "季度战略复盘会议", "en": "季度战略复盘会议" },
  "partner-process.344": { "zh": "年度合作续约与升级规划", "en": "年度合作续约与升级规划" },
  "partner-process.346": { "zh": "7×24小时专属服务热线支持", "en": "7×24h专属服务热线支持" },
  "partner-process.348": { "zh": "联合市场活动与品牌曝光机会", "en": "联合市场活动与品牌曝光机会" },
  "partner-process.356": { "zh": "常见问题", "en": "常见问题" },
  "partner-process.359": { "zh": "❓ 合作需要什么条件？", "en": "❓ 合作需要什么条件？" },
  "partner-process.360": { "zh": "我们欢迎具备合法经营资质、良好行业口碑、稳定客户资源的企业或个人加入合作网络。不同合作类型有具体要求——例如船厂代理需有船舶销售资质，码头合作需有港口运营许可。请联系我们获取详细的准入条件清单。", "en": "我们欢迎具备合法经营资质、良好行业口碑、稳定客户资源的企业或个人加入合作网络。不同合作类型有具体要求——例如Shipyard代理需有船舶销售资质，码头合作需有港口运营许可。请Contact Us获取详细的准入条件清单。" },
  "partner-process.362": { "zh": "❓ 从提交到签约一般需要多长时间？", "en": "❓ 从Submit到签约一般需要多长时间？" },
  "partner-process.363": { "zh": "整个流程通常需要 **3-6周**，具体取决于合作类型和复杂程度。简单的渠道代理合作可在2周内完成签约；复杂的战略合资项目可能需要2-3个月的深度谈判。", "en": "整个流程通常需要 **3-6周**，具体取决于合作类型和复杂程度。简单的渠道代理合作可在2周内完成签约；复杂的战略合资项目可能需要2-3个月的深度谈判。" },
  "partner-process.365": { "zh": "❓ 合作的最低投入是什么？", "en": "❓ 合作的最低投入是什么？" },
  "partner-process.366": { "zh": "根据合作类型不同，投入门槛也不同。渠道代理几乎零成本启动（仅需完成培训和认证）；品牌联名可能需要一定的市场推广预算；而战略投资类合作则根据具体项目商议。我们为每种合作类型设计了灵活的准入方案。", "en": "根据合作类型不同，投入门槛也不同。渠道代理几乎零成本启动（仅需完成培训和认证）；品牌联名可能需要一定的市场推广预算；而战略投资类合作则根据具体项目商议。我们为每种合作类型设计了灵活的准入方案。" },
  "partner-process.368": { "zh": "❓ 如何保障合作双方的权益？", "en": "❓ 如何保障合作双方的权益？" },
  "partner-process.369": { "zh": "所有合作均通过正式法律协议明确双方权责，包含：排他性条款、收益分配机制、知识产权归属、保密义务、违约责任及争议解决方式。我们合作的国际律所为协议执行提供法律保障。", "en": "所有合作均通过正式法律协议明确双方权责，包含：排他性条款、收益分配机制、知识产权归属、保密义务、违约责任及争议解决方式。我们合作的国际律所为协议执行提供法律保障。" },
  "partner-process.371": { "zh": "❓ 可以同时参与多种类型的合作吗？", "en": "❓ 可以同时参与多种类型的合作吗？" },
  "partner-process.372": { "zh": "当然可以！许多合作伙伴与我们同时开展多种类型的合作。例如：一家高端酒店既是「生活方式合作伙伴」，同时也作为「渠道代理」向我们推荐游艇客户。多重合作身份可享受叠加权益与更高返佣比例。", "en": "当然可以！许多合作伙伴与我们同时开展多种类型的合作。例如：一家高端酒店既是「生活方式合作伙伴」，同时也作为「渠道代理」向我们RecommendedYacht客户。多重合作身份可享受叠加权益与更高返佣比例。" },
  "partner-process.380": { "zh": "开启", "en": "开启" },
  "partner-process.381": { "zh": "战略合作", "en": "战略合作" },
  "partner-process.384": { "zh": "无论您是船厂、码头运营商、服务商还是品牌方，我们都期待与您携手共创价值。", "en": "无论您是Shipyard、码头运营商、服务商还是品牌方，我们都期待与您携手共创价值。" },
  "partner-process.386": { "zh": "📝 提交合作意向 →", "en": "📝 Submit合作意向 →" },
  "partner-process.402": { "zh": "奇幻假期", "en": "Fantastic Vacation" },
  "partner-process.404": { "zh": "FANTASTIC VACATION", "en": "FANTASTIC VACATION" },
  "partner-process.408": { "zh": "「探索全球，不负假期」", "en": "「探索全球，不负假期」" },
  "partner-process.411": { "zh": "奇幻假期实业有限公司深耕高端游艇行业15年，为200+全球高净值客户提供游艇定制、租赁、托管全产业链一站式服务。", "en": "Fantastic Vacation实业有限公司深耕高端Yacht行业15年，为200+Global High-Net-Worth Clients提供YachtCustom、Charter、托管全产业链一站式服务。" },
  "partner-process.416": { "zh": "微信公众号", "en": "WeChat Official Account" },
  "partner-process.421": { "zh": "微博", "en": "Weibo" },
  "partner-process.426": { "zh": "抖音", "en": "TikTok (Douyin)" },
