  "custom.257": { "zh": "✦ 全流程定制 ✦", "en": "✦ 全流程Custom ✦" },
  "custom.259": { "zh": "私人游艇", "en": "私人Yacht" },
  "custom.262": { "zh": "每一艘游艇，都是船东海上私人生活方式的专属艺术品", "en": "每一艘Yacht，都是船东海上私人生活方式的专属艺术品" },
  "custom.266": { "zh": "年定制经验", "en": "年Custom经验" },
  "custom.269": { "zh": "交付游艇", "en": "交付Yacht" },
  "custom.272": { "zh": "全球服务网点", "en": "全球服务网点" },
  "custom.275": { "zh": "客户满意度%", "en": "客户满意度%" },
  "custom.288": { "zh": "每一寸空间，", "en": "每一寸空间，" },
  "custom.291": { "zh": "在奇幻假期，我们深信真正的奢华并非堆砌昂贵材质，而是对每一位船东生活方式的深刻理解与精准诠释。从地中海的蔚蓝海岸到加勒比的碧波万顷，我们为全球精英阶层打造独一无二的海上移动行宫——这不仅是一艘游艇，更是您个人品味、生活哲学与航海梦想的具象化呈现。", "en": "在Fantastic Vacation，我们深信真正的奢华并非堆砌昂贵材质，而是对每一位船东生活方式的深刻理解与精准诠释。从Mediterranean的蔚蓝海岸到加勒比的碧波万顷，我们为全球精英阶层打造独一无二的海上移动行宫——这不仅是一艘Yacht，更是您个人品味、生活哲学与航海梦想的具象化呈现。" },
  "custom.293": { "zh": "我们汇聚意大利Benetti设计工作室的东方美学造诣、荷兰Feadship的精密建造工艺、德国MTU的动力工程实力，整合全球最优秀的游艇产业链资源，确保每一艘交付的定制游艇都达到国际最高标准。", "en": "我们汇聚意大利Benetti设计工作室的东方美学造诣、荷兰Feadship的精密建造工艺、德国MTU的动力工程实力，整合全球最优秀的Yacht产业链资源，确保每一艘交付的CustomYacht都达到国际最高标准。" },
  "custom.297": { "zh": "意大利原创设计", "en": "意大利原创设计" },
  "custom.301": { "zh": "荷兰顶级船厂", "en": "荷兰顶级Shipyard" },
  "custom.305": { "zh": "德国精工动力", "en": "德国精工动力" },
  "custom.309": { "zh": "全球供应链", "en": "全球供应链" },
  "custom.322": { "zh": "全流程定制能力", "en": "全流程Custom能力" },
  "custom.325": { "zh": "从最初的概念草图到最终的海上交付，奇幻假期的定制服务涵盖游艇诞生的每一个环节，每一个细节都由专业团队精心把控", "en": "从最初的概念草图到最终的海上交付，Fantastic Vacation的Custom服务涵盖Yacht诞生的每一个环节，每一个细节都由专业团队精心把控" },
  "custom.335": { "zh": "STEP 01", "en": "STEP 01" },
  "custom.337": { "zh": "专属咨询", "en": "专属咨询" },
  "custom.339": { "zh": "资深游艇顾问一对一深度沟通，全面了解您的航海愿景与审美偏好。从首次接触到方案蓝图，全程由专属项目顾问跟进，确保每一个需求都被精准捕捉与专业回应。", "en": "资深Yacht顾问一对一深度沟通，全面了解您的航海愿景与审美偏好。从首次接触到方案蓝图，全程由专属项目顾问跟进，确保每一个需求都被精准捕捉与专业回应。" },
  "custom.342": { "zh": "一对一深度需求调研", "en": "一对一深度需求调研" },
  "custom.344": { "zh": "航海愿景与生活方式访谈", "en": "航海愿景与生活方式访谈" },
  "custom.346": { "zh": "预算规划与使用场景分析", "en": "预算规划与使用场景分析" },
  "custom.348": { "zh": "船东专属项目顾问对接", "en": "船东专属项目顾问对接" },
  "custom.350": { "zh": "法规与海事政策专业咨询", "en": "法规与海事政策专业咨询" },
  "custom.352": { "zh": "初步方案沟通与预期管理", "en": "初步方案沟通与预期管理" },
  "custom.354": { "zh": "竞品对比与市场趋势解读", "en": "竞品对比与市场趋势解读" },
  "custom.356": { "zh": "定制合同条款详细说明", "en": "Custom合同条款详细说明" },
  "custom.367": { "zh": "STEP 02", "en": "STEP 02" },
  "custom.369": { "zh": "概念设计", "en": "概念设计" },
  "custom.371": { "zh": "国际顶级游艇设计师执笔，从船体流体力学优化到内饰空间美学，全方位呈现梦想之艇的完整蓝图。提供1:1实体模型制作与VR全景虚拟体验，让您在建造前即可身临其境。", "en": "国际顶级YachtDesigner执笔，从船体流体力学优化到内饰空间美学，全方位呈现梦想之艇的完整蓝图。提供1:1实体模型制作与VR全景虚拟体验，让您在建造前即可身临其境。" },
  "custom.374": { "zh": "船型选择与流体力学优化", "en": "船型选择与流体力学优化" },
  "custom.376": { "zh": "外观风格设计与配色方案", "en": "外观风格设计与配色方案" },
  "custom.378": { "zh": "内饰主题与空间功能规划", "en": "内饰主题与空间功能规划" },
  "custom.380": { "zh": "1:1实体模型制作（对标Princess）", "en": "1:1实体模型制作（对标Princess）" },
  "custom.382": { "zh": "3D效果图与VR全景预览", "en": "3D效果图与VR全景预览" },
  "custom.384": { "zh": "多方案对比与迭代优化", "en": "多方案对比与迭代优化" },
  "custom.386": { "zh": "品牌标识与船名视觉设计", "en": "品牌标识与船名视觉设计" },
  "custom.388": { "zh": "灯光声学系统初步方案", "en": "灯光声学系统初步方案" },
  "custom.399": { "zh": "STEP 03", "en": "STEP 03" },
  "custom.401": { "zh": "材质甄选", "en": "材质甄选" },
  "custom.403": { "zh": "全球顶级材料库为您敞开——意大利Nappa皮革、缅甸百年柚木、瑞士精密仪器、卡拉拉白大理石与航空级铝合金饰面，每一种材质都经过严苛筛选与环保认证。", "en": "全球顶级材料库为您敞开——意大利Nappa皮革、缅甸百年柚木、瑞士精密仪器、卡拉拉白大理石与航空级铝合金饰面，每一种材质都经过严苛Filter与环保认证。" },
  "custom.406": { "zh": "意大利顶级皮革 / 缅甸百年柚木", "en": "意大利顶级皮革 / 缅甸百年柚木" },
  "custom.408": { "zh": "瑞士精密仪器 / 卡拉拉大理石", "en": "瑞士精密仪器 / 卡拉拉大理石" },
  "custom.410": { "zh": "环保材料认证与绿色建造方案", "en": "环保材料认证与绿色建造方案" },
  "custom.412": { "zh": "色彩搭配与纹理系统设计", "en": "色彩搭配与纹理系统设计" },
  "custom.414": { "zh": "材质打样与多轮确认流程", "en": "材质打样与多轮确认流程" },
  "custom.416": { "zh": "定制化五金与细节配件选择", "en": "Custom化五金与细节配件选择" },
  "custom.418": { "zh": "全球供应商直采与品质溯源", "en": "全球供应商直采与品质溯源" },
  "custom.420": { "zh": "防火阻燃与海洋环境适配检测", "en": "防火阻燃与海洋环境适配检测" },
  "custom.431": { "zh": "STEP 04", "en": "STEP 04" },
  "custom.433": { "zh": "精密建造", "en": "精密建造" },
  "custom.435": { "zh": "自有船坞与荷兰Feadship、Heesen等全球顶级船厂联合建造。采用航天级焊接工艺与碳纤维/铝合金复合船体技术，每一个连接点都经过严苛品控与第三方检测。", "en": "自有船坞与荷兰Feadship、Heesen等全球顶级Shipyard联合建造。采用航天级焊接工艺与碳纤维/铝合金复合船体技术，每一个连接点都经过严苛品控与第三方检测。" },
  "custom.438": { "zh": "自有船坞与全球顶级联合建造", "en": "自有船坞与全球顶级联合建造" },
  "custom.440": { "zh": "航天级焊接 / 碳纤维复合工艺", "en": "航天级焊接 / 碳纤维复合工艺" },
  "custom.442": { "zh": "ISO 9001全程质量管控体系", "en": "ISO 9001全程质量管控体系" },
  "custom.444": { "zh": "关键节点第三方独立检测验收", "en": "关键节点第三方独立检测验收" },
  "custom.446": { "zh": "建造周期精确规划与进度管控", "en": "建造周期精确规划与进度管控" },
  "custom.448": { "zh": "建造进度App实时更新推送", "en": "建造进度App实时更新推送" },
  "custom.450": { "zh": "客户现场参观与关键节点见证", "en": "客户现场参观与关键节点见证" },
  "custom.452": { "zh": "环保排放与能效标准认证", "en": "环保排放与能效标准认证" },
  "custom.463": { "zh": "STEP 05", "en": "STEP 05" },
  "custom.465": { "zh": "海试交付", "en": "海试交付" },
  "custom.467": { "zh": "严苛的72小时海上性能综合测试，涵盖航速、稳定性、操控性、设备可靠性等全方位检测。交付前进行全面清洁养护与操作培训，让您的首航之旅完美启程。", "en": "严苛的72h海上性能综合测试，涵盖Speed、稳定性、操控性、设备可靠性等全方位检测。交付前进行全面清洁养护与操作培训，让您的首航之旅完美启程。" },
  "custom.470": { "zh": "72小时海上性能综合测试", "en": "72h海上性能综合测试" },
  "custom.472": { "zh": "航速/稳定性/操控性全面检测", "en": "Speed/稳定性/操控性全面检测" },
  "custom.474": { "zh": "全船设备调试与系统优化", "en": "全船设备调试与系统优化" },
  "custom.476": { "zh": "交付前深度清洁与养护处理", "en": "交付前深度清洁与养护处理" },
  "custom.478": { "zh": "船东操作培训与安全指导", "en": "船东操作培训与安全指导" },
  "custom.480": { "zh": "专属交付仪式与纪念礼赠", "en": "专属交付仪式与纪念礼赠" },
  "custom.482": { "zh": "海事法规文件与证书办理协助", "en": "海事法规文件与证书办理协助" },
  "custom.484": { "zh": "首航陪航与技术支持保障", "en": "首航陪航与技术支持保障" },
  "custom.495": { "zh": "STEP 06", "en": "STEP 06" },
  "custom.497": { "zh": "终身陪伴", "en": "终身陪伴" },
  "custom.499": { "zh": "交付只是服务的开始。全球12座城市维保中心、7×24小时海上应急响应、专属管家年度回访，从日常维护到远洋救援，我们始终守护在您身边。", "en": "交付只是服务的开始。全球12座城市维保中心、7×24h海上应急响应、专属管家年度回访，从日常维护到远洋救援，我们始终守护在您身边。" },
  "custom.502": { "zh": "全球12座城市维保中心网络", "en": "全球12座城市维保中心网络" },
  "custom.504": { "zh": "7×24小时海上应急响应团队", "en": "7×24h海上应急响应团队" },
  "custom.506": { "zh": "专属管家年度回访与巡检", "en": "专属管家年度回访与巡检" },
  "custom.508": { "zh": "定期维护计划与智能系统迭代", "en": "定期维护计划与智能系统迭代" },
  "custom.510": { "zh": "升级改装与现代化改造服务", "en": "升级改装与现代化改造服务" },
  "custom.512": { "zh": "二手转售与置换评估协助", "en": "二手转售与置换评估协助" },
  "custom.514": { "zh": "全球航线规划与港口停靠支持", "en": "全球航线规划与港口停靠支持" },
  "custom.516": { "zh": "船员培训与持证管理体系", "en": "船员培训与持证管理体系" },
  "custom.529": { "zh": "定制维度与特色服务", "en": "Custom维度与特色服务" },
  "custom.542": { "zh": "从船体流线到品牌标识，每一处外观细节都彰显独特个性。我们的外观设计团队将根据您的审美偏好与使用场景，打造独一无二的视觉识别体系。", "en": "从船体流线到品牌标识，每一处外观细节都彰显独特个性。我们的外观设计团队将根据您的审美偏好与使用场景，打造独一无二的视觉识别体系。" },
  "custom.545": { "zh": "船体线条优化", "en": "船体线条优化" },
  "custom.546": { "zh": "专属配色方案", "en": "专属配色方案" },
  "custom.547": { "zh": "品牌标识定制", "en": "品牌标识Custom" },
  "custom.548": { "zh": "船名雕刻艺术", "en": "船名雕刻艺术" },
  "custom.549": { "zh": "特殊涂装工艺", "en": "特殊涂装工艺" },
  "custom.550": { "zh": "LED动态灯效", "en": "LED动态灯效" },
  "custom.559": { "zh": "主题风格随心选——东方美学的禅意雅致、现代极简的利落线条、复古奢华的宫廷气派。空间功能按需改造，从私人影院到SPA水疗房，从海上健身房到总裁办公室。", "en": "主题风格随心选——东方美学的禅意雅致、现代极简的利落线条、复古奢华的宫廷气派。空间功能按需改造，从私人影院到SPA水疗房，从海上健身房到总裁办公室。" },
  "custom.562": { "zh": "东方美学/现代极简/复古奢华", "en": "东方美学/现代极简/复古奢华" },
  "custom.563": { "zh": "健身房/影音室/SPA房", "en": "健身房/影音室/SPA房" },
  "custom.564": { "zh": "家具软装全套定制", "en": "家具软装全套Custom" },
  "custom.565": { "zh": "灯光氛围系统", "en": "灯光氛围系统" },
  "custom.566": { "zh": "艺术品陈设搭配", "en": "艺术品陈设搭配" },
  "custom.575": { "zh": "超越传统游艇的功能边界。智能中控系统一键掌控全船设备，卫星通信确保全球互联，水下灯光打造梦幻夜景，直升机起降平台拓展出行半径。", "en": "超越传统Yacht的功能边界。智能中控系统一键掌控全船设备，卫星通信确保全球互联，水下灯光打造梦幻夜景，直升机起降平台拓展出行半径。" },
  "custom.578": { "zh": "航速与动力系统优化", "en": "Speed与动力系统优化" },
  "custom.579": { "zh": "全屋智能中控系统", "en": "全屋智能中控系统" },
  "custom.580": { "zh": "卫星通信与联网", "en": "卫星通信与联网" },
  "custom.581": { "zh": "海钓平台/潜水装备舱", "en": "海钓平台/潜水装备舱" },
  "custom.582": { "zh": "直升机起降平台", "en": "直升机起降平台" },
  "custom.591": { "zh": "从登艇那一刻起的全方位尊享体验。米其林主厨定制专属菜单，私人航线规划师设计环球航行路线，全球港口VIP停靠协助，会员制特权礼遇贯穿始终。", "en": "从登艇那一刻起的全方位尊享体验。米其林主厨Custom专属菜单，私人航线规划师设计环球航行路线，全球港口VIP停靠协助，会员制特权礼遇贯穿始终。" },
  "custom.594": { "zh": "专属管家全天候服务", "en": "专属管家全天候服务" },
  "custom.595": { "zh": "米其林主厨定制菜单", "en": "米其林主厨Custom菜单" },
