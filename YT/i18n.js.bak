  "charter.1013": { "zh": "不同航线需要不同的船型配置。我们帮您快速找到最适合您出行场景的完美游艇", "en": "不同航线需要不同的船型配置。我们帮您快速找到最适合您出行场景的完美Yacht" },
  "charter.1020": { "zh": "飞桥系列 18-45M", "en": "Flybridge Series 18-45M" },
  "charter.1022": { "zh": "适合近海度假 · 家庭出游 · 派对", "en": "适合近海度假 · 家庭出游 · 派对" },
  "charter.1024": { "zh": "飞桥甲板提供360°开阔视野，阳光充足，适合家庭度假、朋友派对、商务会晤，性价比最高的豪华游艇之选。", "en": "飞桥甲板提供360°开阔视野，阳光充足，适合家庭度假、朋友派对、商务会晤，性价比最高的LuxuryYacht之选。" },
