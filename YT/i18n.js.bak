  "cases-custom.277": { "zh": "82米超级游艇「幻蓝号」Fantasy Blue", "en": "82米SuperYacht「幻蓝号」Fantasy Blue" },
  "cases-custom.279": { "zh": "中东王室委托的全案定制项目，历时38个月完成。搭载直升机平台、潜艇车库、医疗中心及IMAX影院。2024年荣获Asia Boating Awards年度最佳定制游艇大奖。", "en": "Middle East王室委托的Full Customization项目，历时38个月完成。搭载直升机平台、潜艇车库、医疗中心及IMAX影院。2024年荣获Asia Boating Awards年度最佳CustomYacht大奖。" },
  "cases-custom.282": { "zh": "全案定制", "en": "Full Customization" },
  "cases-custom.284": { "zh": "82m", "en": "82m" },
  "cases-custom.286": { "zh": "中东海域", "en": "Middle East海域" },
