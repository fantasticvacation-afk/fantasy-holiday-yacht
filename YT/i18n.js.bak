  "charter.876": { "zh": "航线推荐", "en": "航线Recommended" },
  "charter.877": { "zh": "根据需求提供3-5个备选航线方案，详细介绍每条航线的亮点与差异，帮您找到最适合的选择", "en": "根据需求提供3-5个备选航线方案，详细介绍每条航线的亮点与差异，帮您找到最适合的选择" },
  "charter.879": { "zh": "03", "en": "03" },
  "charter.881": { "zh": "方案确认", "en": "方案确认" },
  "charter.882": { "zh": "提供详细的行程规划、游艇规格、餐饮方案与完整报价单，签署服务合同确认所有细节", "en": "提供详细的行程规划、Yacht规格、餐饮方案与完整报价单，签署服务合同确认所有细节" },
  "charter.884": { "zh": "04", "en": "04" },
  "charter.886": { "zh": "定金锁定", "en": "定金锁定" },
  "charter.887": { "zh": "支付50%定金锁定档期，团队立即启动准备工作，确认船型、船员配置与港口安排", "en": "支付50%定金锁定档期，团队立即启动准备工作，确认船型、船员配置与港口安排" },
  "charter.889": { "zh": "05", "en": "05" },
  "charter.891": { "zh": "行前准备", "en": "行前准备" },
  "charter.892": { "zh": "办理港口通关、预订岸上活动、定制餐饮菜单、提供行前须知与登船指南", "en": "办理港口通关、预订岸上活动、Custom餐饮菜单、提供行前须知与登船指南" },
  "charter.894": { "zh": "06", "en": "06" },
  "charter.896": { "zh": "登船启航", "en": "登船启航" },
  "charter.897": { "zh": "专属船长主持登船Briefing，全面介绍船只与航线，7×24小时专属服务随即开始", "en": "专属船长主持登船Briefing，全面介绍船只与航线，7×24h专属服务随即开始" },
  "charter.899": { "zh": "07", "en": "07" },
  "charter.901": { "zh": "行程执行", "en": "行程执行" },
  "charter.902": { "zh": "按规划航线巡航，支持每日灵活调整，船长与管家全程提供专业服务与安全保障", "en": "按规划航线巡航，支持每日灵活调整，船长与管家全程提供专业服务与安全保障" },
  "charter.904": { "zh": "08", "en": "08" },
