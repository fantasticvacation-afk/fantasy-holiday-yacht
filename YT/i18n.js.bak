  "management.282": { "zh": "%客户满意度", "en": "%客户满意度" },
  "management.292": { "zh": "核心服务模块", "en": "核心服务模块" },
  "management.294": { "zh": "六大维度覆盖游艇资产管理全生命周期，一站式解决所有运营难题", "en": "六大维度覆盖Yacht资产管理全生命周期，一站式解决所有运营难题" },
  "management.306": { "zh": "日常运营管理", "en": "日常运营管理" },
  "management.308": { "zh": "全方位接管游艇日常运营事务，从船员调度到财务核算，让您真正实现「拥有但不操心」的轻奢生活方式。", "en": "全方位接管Yacht日常运营事务，从船员调度到财务核算，让您真正实现「拥有但不操心」的轻奢生活方式。" },
  "management.311": { "zh": "船员派遣与管理", "en": "船员派遣与管理" },
  "management.313": { "zh": "航行日程调度", "en": "航行日程调度" },
  "management.315": { "zh": "物资供应链", "en": "物资供应链" },
  "management.317": { "zh": "财务报表系统", "en": "财务报表系统" },
  "management.319": { "zh": "船东专属APP", "en": "船东专属APP" },
  "management.331": { "zh": "定期保养维护", "en": "定期保养维护" },
  "management.333": { "zh": "基于每艘游艇的材质、航区和使用频率，定制科学严谨的预防性维护计划，将故障消灭在萌芽状态。", "en": "基于每艘Yacht的材质、航区和使用频率，Custom科学严谨的预防性维护计划，将故障消灭在萌芽状态。" },
  "management.336": { "zh": "发动机深度保养", "en": "Engine深度保养" },
  "management.338": { "zh": "防污漆年度更新", "en": "防污漆年度更新" },
  "management.340": { "zh": "导航设备校准", "en": "导航设备校准" },
  "management.342": { "zh": "安全系统检测", "en": "安全系统检测" },
  "management.344": { "zh": "季节性入坞维护", "en": "季节性入坞维护" },
  "management.354": { "zh": "⚙️", "en": "⚙️" },
  "management.356": { "zh": "专业维修服务", "en": "专业维修服务" },
  "management.358": { "zh": "配备资深轮机工程师团队，提供从紧急抢修到系统性大修的全谱系维修能力，确保最短停航时间。", "en": "配备资深轮机工程师团队，提供从紧急抢修到系统性大修的全谱系维修能力，确保最短停航时间。" },
  "management.361": { "zh": "24/7紧急抢修", "en": "24/7紧急抢修" },
  "management.363": { "zh": "船体损伤修复", "en": "船体损伤修复" },
  "management.365": { "zh": "机械系统大修", "en": "机械系统大修" },
  "management.367": { "zh": "电子设备升级", "en": "电子设备升级" },
  "management.369": { "zh": "内饰翻新改造", "en": "内饰翻新改造" },
  "management.381": { "zh": "海事合规代办", "en": "海事合规代办" },
  "management.383": { "zh": "精通国际海事法规体系（SOLAS/MLC/ISPS），为您提供从船级社检验到证书续期的全套合规解决方案。", "en": "精通国际海事法规体系（SOLAS/MLC/ISPS），为您提供从船级社检验到证书续期的全套合规解决方案。" },
  "management.386": { "zh": "船级社检验协调", "en": "船级社检验协调" },
  "management.388": { "zh": "法定证书更新", "en": "法定证书更新" },
  "management.390": { "zh": "船旗国注册续期", "en": "船旗国注册续期" },
  "management.392": { "zh": "环保认证维护", "en": "环保认证维护" },
  "management.394": { "zh": "安全管理体系审核", "en": "安全管理体系审核" },
  "management.404": { "zh": "🛡️", "en": "🛡️" },
  "management.406": { "zh": "保险理赔协助", "en": "保险理赔协助" },
  "management.408": { "zh": "与全球顶级H&amp;M保险公司及P&amp;I俱乐部建立战略合作，为您构建完整的风险保障与快速理赔通道。", "en": "与全球顶级H&amp;M保险公司及P&amp;I俱乐部建立战略合作，为您构建完整的风险保障与快速理赔通道。" },
  "management.411": { "zh": "H&amp;M保险方案", "en": "H&amp;M保险方案" },
  "management.413": { "zh": "P&amp;I俱乐部对接", "en": "P&amp;I俱乐部对接" },
  "management.415": { "zh": "事故全程处理", "en": "事故全程处理" },
  "management.417": { "zh": "损失评估谈判", "en": "损失评估谈判" },
  "management.419": { "zh": "风险预防咨询", "en": "风险预防咨询" },
  "management.431": { "zh": "资产保值规划", "en": "资产保值规划" },
  "management.433": { "zh": "依托深厚的行业数据积累和市场洞察力，为您的游艇资产提供从价值评估到传承规划的长期财富管理建议。", "en": "依托深厚的行业数据积累和市场洞察力，为您的Yacht资产提供从价值评估到传承规划的长期财富管理建议。" },
  "management.436": { "zh": "市场价值评估", "en": "市场价值评估" },
  "management.438": { "zh": "最佳出售时机", "en": "最佳出售时机" },
  "management.440": { "zh": "改装升级建议", "en": "改装升级建议" },
  "management.442": { "zh": "成本效益优化", "en": "成本效益优化" },
  "management.444": { "zh": "税务合规咨询", "en": "税务合规咨询" },
  "management.457": { "zh": "托管服务流程", "en": "托管服务流程" },
  "management.459": { "zh": "六步标准化流程，从签约到交付，全程透明可控", "en": "六步标准化流程，从签约到交付，全程透明可控" },
  "management.465": { "zh": "01", "en": "01" },
  "management.467": { "zh": "资产评估与需求分析", "en": "资产评估与需求分析" },
  "management.469": { "zh": "全面勘察游艇现状，包括船龄、设备状况、证书有效期、历史维修记录等，结合船东使用偏好制定个性化托管方案。", "en": "全面勘察Yacht现状，包括船龄、设备状况、证书有效期、历史维修记录等，结合船东使用偏好制定个性化托管方案。" },
  "management.473": { "zh": "02", "en": "02" },
  "management.475": { "zh": "定制化托管方案设计", "en": "Custom化托管方案设计" },
  "management.477": { "zh": "根据评估结果，量身定制包含人员配置、维护计划、预算分配、航线规划的完整托管方案，明确服务范围与KPI指标。", "en": "根据评估结果，量身Custom包含人员配置、维护计划、预算分配、航线规划的完整托管方案，明确Service Scope与KPI指标。" },
  "management.481": { "zh": "03", "en": "03" },
  "management.483": { "zh": "专业团队入驻交接", "en": "专业团队入驻交接" },
  "management.485": { "zh": "派遣持证船长、轮机长及服务团队完成全面交接，建立数字化档案管理系统，开通船东专属APP实时监控端口。", "en": "派遣持证船长、轮机长及服务团队完成全面交接，建立数字化档案管理系统，开通船东专属APP实时监控端口。" },
  "management.489": { "zh": "04", "en": "04" },
  "management.491": { "zh": "常态化运营与维护执行", "en": "常态化运营与维护执行" },
  "management.493": { "zh": "按计划执行日常运营调度、定期巡检保养、月度财务报告、季度安全审计，所有关键节点均需船东确认后推进。", "en": "按计划执行日常运营调度、定期巡检保养、月度财务报告、季度安全审计，所有关键节点均需船东确认后推进。" },
  "management.498": { "zh": "05", "en": "05" },
  "management.500": { "zh": "年度综合评估报告", "en": "年度综合评估报告" },
  "management.502": { "zh": "每年出具详尽的《游艇资产健康报告》，含技术状态评级、市场估值变化、下一年度优化建议及预算规划。", "en": "每年出具详尽的《Yacht资产健康报告》，含技术状态评级、市场估值变化、下一年度优化建议及预算规划。" },
  "management.506": { "zh": "06", "en": "06" },
  "management.508": { "zh": "持续优化与增值服务", "en": "持续优化与增值服务" },
  "management.510": { "zh": "根据使用数据和行业趋势，主动提出改装升级、航线拓展、共享租赁等增值方案，助力资产持续升值。", "en": "根据使用数据和行业趋势，主动提出改装升级、航线拓展、共享Charter等增值方案，助力资产持续升值。" },
  "management.521": { "zh": "托管服务套餐", "en": "托管服务套餐" },
  "management.523": { "zh": "三档灵活方案，满足不同规模与需求的船东选择", "en": "三档灵活方案，满足不同规模与需求的船东选择" },
  "management.531": { "zh": "基础托管", "en": "基础托管" },
