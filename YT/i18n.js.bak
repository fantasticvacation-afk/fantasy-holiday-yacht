  "custom.598": { "zh": "会员制特权礼遇", "en": "会员制特权礼遇" },
  "custom.611": { "zh": "1:1 实体模型", "en": "1:1 实体模型" },
  "custom.615": { "zh": "1:1实体模型制作服务", "en": "1:1实体模型制作服务" },
  "custom.617": { "zh": "VR全景虚拟体验", "en": "VR全景虚拟体验" },
  "custom.621": { "zh": "1:1等比例实体模型，完整还原外观与内部空间布局", "en": "1:1等比例实体模型，完整还原外观与内部空间布局" },
  "custom.623": { "zh": "VR全景漫游系统，沉浸式体验每个舱室与甲板区域", "en": "VR全景漫游系统，沉浸式体验每个舱室与甲板区域" },
  "custom.625": { "zh": "实时材质替换功能，即时预览不同皮革/木材/配色效果", "en": "实时材质替换功能，即时预览不同皮革/木材/配色效果" },
  "custom.627": { "zh": "光照模拟系统，感受不同时段的自然采光变化", "en": "光照模拟系统，感受不同时段的自然采光变化" },
  "custom.629": { "zh": "家具摆放互动调整，直观验证空间舒适度", "en": "家具摆放互动调整，直观验证空间舒适度" },
  "custom.631": { "zh": "多人协同评审模式，家庭成员可远程参与决策", "en": "多人协同评审模式，家庭成员可远程参与决策" },
  "custom.644": { "zh": "定制案例展示", "en": "CustomCase Showcase" },
  "custom.647": { "zh": "每一艘交付的游艇，都是一段独一无二的定制传奇", "en": "每一艘交付的Yacht，都是一段独一无二的Custom传奇" },
  "custom.654": { "zh": "Case 001 · 君临系列", "en": "Case 001 · Monarch Series" },
