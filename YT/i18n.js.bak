  "case-002.350": { "zh": "65米以上超级游艇，可容纳22位宾客及28名服务人员", "en": "65米以上SuperYacht，可容纳22位宾客及28名服务人员" },
  "case-002.352": { "zh": "配备米其林星级主厨，提供多国料理定制服务", "en": "配备米其林星级主厨，提供多国料理Custom服务" },
  "case-002.354": { "zh": "私人潜水教练及水上活动团队，支持深海探险", "en": "私人潜水教练及水上活动团队，支持深海探险" },
  "case-002.356": { "zh": "多语言礼宾团队（英/法/意/德/西），无障碍沟通", "en": "多语言礼宾团队（英/法/意/德/西），无障碍沟通" },
  "case-002.358": { "zh": "12个国家24个港口的靠泊协调与岸上活动安排", "en": "12个国家24个港口的靠泊协调与岸上活动安排" },
