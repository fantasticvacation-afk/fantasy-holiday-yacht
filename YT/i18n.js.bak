  "press.250": { "zh": "媒体报道", "en": "Media Reports" },
  "press.252": { "zh": "奇幻假期fantastic.vacation — 主流媒体持续关注的行业标杆", "en": "Fantastic Vacationfantastic.vacation — 主流媒体持续关注的行业标杆" },
  "press.257": { "zh": "新浪财经", "en": "新浪财经" },
  "press.258": { "zh": "奇幻假期斩获亚洲最佳游艇服务商大奖", "en": "Fantastic Vacation斩获亚洲最佳Yacht服务商大奖" },
  "press.260": { "zh": "2024年12月15日", "en": "2024年12月15日" },
  "press.262": { "zh": "游艇世界杂志", "en": "Yacht世界杂志" },
  "press.263": { "zh": "专访奇幻假期创始人：游艇行业的东方力量", "en": "专访Fantastic Vacation创始人：Yacht行业的东方力量" },
  "press.264": { "zh": "从一家小型游艇租赁公司到亚洲顶级游艇服务集团，奇幻假期用10年时间书写了中国游艇行业的传奇。创始人接受本刊独家专访，分享成功背后的故事。", "en": "从一家小型YachtCharter公司到亚洲顶级Yacht服务集团，Fantastic Vacation用10年时间书写了中国Yacht行业的传奇。创始人接受本刊独家专访，分享成功背后的故事。" },
  "press.265": { "zh": "2024年11月20日", "en": "2024年11月20日" },
  "press.267": { "zh": "凤凰网财经", "en": "凤凰网财经" },
  "press.269": { "zh": "国内首艘完全自主设计的80米以上超级游艇正式交付，标志着中国游艇制造业迈入世界顶级水平。奇幻假期在游艇定制领域的突破引发行业震动。", "en": "国内首艘完全自主设计的80米以上SuperYacht正式交付，标志着中国Yacht制造业迈入世界顶级水平。Fantastic Vacation在YachtCustom领域的突破引发行业震动。" },
  "press.270": { "zh": "2024年10月08日", "en": "2024年10月08日" },
  "press.272": { "zh": "腾讯财经", "en": "腾讯财经" },
  "press.273": { "zh": "海上婚礼新标杆：奇幻假期加勒比海案例解析", "en": "海上婚礼新标杆：Fantastic VacationCaribbean案例解析" },
  "press.275": { "zh": "2024年9月12日", "en": "2024年9月12日" },
  "press.277": { "zh": "网易新闻", "en": "网易新闻" },
  "press.278": { "zh": "奇幻假期完成中东王室5年全托管项目", "en": "Fantastic Vacation完成Middle East王室5年全托管项目" },
  "press.279": { "zh": "中东王室船队5年全托管服务项目圆满收官，奇幻假期以零安全事故的完美表现，赢得国际顶级客户的认可，进一步巩固全球市场地位。", "en": "Middle East王室船队5年全托管服务项目圆满收官，Fantastic Vacation以零安全事故的完美表现，赢得国际顶级客户的认可，进一步巩固全球市场地位。" },
  "press.280": { "zh": "2024年8月25日", "en": "2024年8月25日" },
  "press.282": { "zh": "福布斯中国", "en": "福布斯中国" },
