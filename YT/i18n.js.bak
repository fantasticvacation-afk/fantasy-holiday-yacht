  "case-005.350": { "zh": "85米以上超级游艇，可容纳120位宾客及45名服务人员", "en": "85米以上SuperYacht，可容纳120位宾客及45名服务人员" },
  "case-005.352": { "zh": "配备直升机平台，实现新娘空中入场与VIP客人接驳", "en": "配备直升机平台，实现新娘空中入场与VIP客人接驳" },
  "case-005.354": { "zh": "水下派对空间，支持浮潜与水下摄影", "en": "水下派对空间，支持浮潜与水下摄影" },
  "case-005.356": { "zh": "中式婚礼仪式场地（敬茶、拜堂）与西式晚宴场地", "en": "中式婚礼仪式场地（敬茶、拜堂）与西式晚宴场地" },
