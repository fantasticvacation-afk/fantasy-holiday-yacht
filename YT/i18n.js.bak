  "case-006.306": { "zh": "企业活动行业奖", "en": "企业活动行业奖" },
  "case-006.308": { "zh": "核心亮点", "en": "核心亮点" },
  "case-006.309": { "zh": "编队航行+活动策划", "en": "编队航行+活动策划" },
  "case-006.310": { "zh": "零安全事故", "en": "零安全事故" },
  "case-006.315": { "zh": "客户需求与项目背景", "en": "客户需求与项目背景" },
  "case-006.316": { "zh": "深度理解客户诉求，定制专属解决方案", "en": "深度理解客户诉求，Custom专属解决方案" },
  "case-006.318": { "zh": "📋 项目背景", "en": "📋 项目背景" },
  "case-006.319": { "zh": "客户为亚太知名跨国企业，计划举办年度高管峰会及团队建设活动。需寻找专业团队提供海上活动全托管服务，包括游艇编队航行、商务会议场地、团队活动策划及全程安全托管。", "en": "客户为亚太知名跨国企业，计划举办年度高管峰会及团队建设活动。需寻找专业团队提供海上活动全托管服务，包括Yacht编队航行、商务会议场地、团队活动策划及全程安全托管。" },
  "case-006.321": { "zh": "🎯 核心诉求", "en": "🎯 核心诉求" },
  "case-006.323": { "zh": "3艘游艇编队航行，可容纳200名高管及嘉宾", "en": "3艘Yacht编队航行，可容纳200名高管及嘉宾" },
  "case-006.325": { "zh": "配备大型会议室，支持视频会议及演讲活动", "en": "配备大型会议室，支持视频会议及演讲活动" },
  "case-006.327": { "zh": "团队建设活动策划（水上运动、岸上探索、主题晚会）", "en": "团队建设活动策划（水上运动、岸上探索、主题晚会）" },
  "case-006.329": { "zh": "米其林主厨团队，提供商务宴请及自助餐服务", "en": "米其林主厨团队，提供商务宴请及自助餐服务" },
  "case-006.331": { "zh": "全程医疗安全保障，配备随船医生及急救设备", "en": "全程医疗安全保障，配备随船医生及急救设备" },
  "case-006.333": { "zh": "企业年会晚会的策划与执行", "en": "企业年会晚会的策划与执行" },
  "case-006.336": { "zh": "⚠️ 项目难点", "en": "⚠️ 项目难点" },
  "case-006.338": { "zh": "3艘游艇编队航行的协调与安全", "en": "3艘Yacht编队航行的协调与安全" },
  "case-006.340": { "zh": "200人规模的海上活动组织与分流", "en": "200人规模的海上活动组织与分流" },
  "case-006.342": { "zh": "企业机密信息的安保与隐私保护", "en": "企业机密信息的安保与隐私保护" },
  "case-006.344": { "zh": "东南亚航线的合规准入办理", "en": "Southeast Asia航线的合规准入办理" },
  "case-006.346": { "zh": "年会晚会的舞台搭建与设备运输", "en": "年会晚会的舞台搭建与设备运输" },
  "case-006.351": { "zh": "核心服务亮点", "en": "核心服务亮点" },
  "case-006.352": { "zh": "差异化能力，打造独一无二的企业年会体验", "en": "差异化能力，打造独一无二的企业年会体验" },
  "case-006.355": { "zh": "🚢 三船编队航行", "en": "🚢 三船编队航行" },
  "case-006.356": { "zh": "55m/68m/75m三艘超级游艇编队航行，配备专业领航与护航船。实现海上会师、编队拍照等独特体验。", "en": "55m/68m/75m三艘SuperYacht编队航行，配备专业领航与护航船。实现海上会师、编队拍照等独特体验。" },
  "case-006.358": { "zh": "🏢 海上会议室", "en": "🏢 海上会议室" },
  "case-006.359": { "zh": "75米旗舰游艇配备200人多功能会议厅，支持视频会议、同声传译、现场演讲。完全满足企业峰会需求。", "en": "75米FlagshipYacht配备200人多功能会议厅，支持视频会议、同声传译、现场演讲。完全满足企业峰会需求。" },
  "case-006.361": { "zh": "🎭 年会晚会定制", "en": "🎭 年会晚会Custom" },
  "case-006.362": { "zh": "专业舞台团队搭建海上舞台，支持灯光音响、LED大屏、直播设备。策划团队全程执行年会晚会。", "en": "专业舞台团队搭建海上舞台，支持灯光音响、LED大屏、直播设备。策划团队全程执行年会晚会。" },
  "case-006.364": { "zh": "👨‍✈️ 120人服务团队", "en": "👨‍✈️ 120人服务团队" },
  "case-006.365": { "zh": "3艘游艇配备120人服务团队（含3艘船员），涵盖会议服务、餐饮服务、活动执行、安保医疗。", "en": "3艘Yacht配备120人服务团队（含3艘船员），涵盖会议服务、餐饮服务、活动执行、安保医疗。" },
  "case-006.367": { "zh": "🏥 全程医疗保障", "en": "🏥 全程医疗保障" },
  "case-006.368": { "zh": "配备2名全科医生及急救设备，实现常见疾病诊疗与紧急医疗转运。新加坡至普吉岛沿线均有合作医院。", "en": "配备2名全科医生及急救设备，实现常见疾病诊疗与紧急医疗转运。新加坡至普吉岛沿线均有合作医院。" },
  "case-006.370": { "zh": "🏆 最佳活动合作伙伴", "en": "🏆 最佳活动合作伙伴" },
  "case-006.376": { "zh": "客户反馈与成果数据", "en": "客户反馈与成果数据" },
  "case-006.377": { "zh": "真实数据，见证服务价值", "en": "真实数据，见证服务价值" },
  "case-006.382": { "zh": "— 企业CEO，2024年2月", "en": "— 企业CEO，2024年2月" },
