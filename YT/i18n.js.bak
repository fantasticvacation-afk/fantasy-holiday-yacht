  "custom.816": { "zh": "12", "en": "12" },
  "custom.817": { "zh": "载客", "en": "Guests" },
  "custom.819": { "zh": "💡 核心亮点：浅吃水岛屿探索 + 星空露营飞桥 + 巴厘岛热带内饰 + 潜水装备舱", "en": "💡 核心亮点：浅Draft岛屿探索 + 星空露营飞桥 + 巴厘岛热带内饰 + 潜水装备舱" },
  "custom.825": { "zh": "Case 010 · 飞桥系列", "en": "Case 010 · Flybridge Series" },
  "custom.827": { "zh": "飞桥35M 太平洋远航版", "en": "飞桥35M 太平洋远航版" },
  "custom.829": { "zh": "跨太平洋长途巡航的专业选手。超长续航油箱设计，配备海水淡化与太阳能辅助供电系统。优化的船体线型减少波浪阻力，提升燃油效率30%。自给自足的生活系统支持连续30天海上生活无需靠港补给。", "en": "跨太平洋长途巡航的专业选手。超长续航油箱设计，配备海水淡化与太阳能辅助供电系统。优化的船体线型减少波浪阻力，提升燃油效率30%。自给自足的生活系统支持连续30天海上生活无需靠港补给。" },
