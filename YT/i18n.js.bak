  "case-002.341": { "zh": "📋 项目背景", "en": "📋 项目背景" },
  "case-002.343": { "zh": "客户为欧洲知名家族企业，计划举办为期30天的地中海深度度假活动，需途经法国、意大利、希腊、西班牙等12个国家，涵盖商务接待、家族聚会、水上活动等多种场景。", "en": "客户为欧洲知名家族企业，计划举办为期30天的Mediterranean深度度假活动，需途经法国、意大利、希腊、西班牙等12个国家，涵盖商务接待、家族聚会、水上活动等多种场景。" },
