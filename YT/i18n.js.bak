  "case-004.477": { "zh": "极地航线合规文件更新", "en": "极地航线合规文件更新" },
  "case-004.484": { "zh": "科研合作拓展", "en": "科研合作拓展" },
  "case-004.487": { "zh": "科研机构合作对接", "en": "科研机构合作对接" },
  "case-004.489": { "zh": "极地科考项目申报支持", "en": "极地科考项目申报支持" },
  "case-004.491": { "zh": "学术论文与成果发布协助", "en": "学术论文与成果发布协助" },
  "case-004.493": { "zh": "环保影响力宣传策划", "en": "环保影响力宣传策划" },
  "case-004.504": { "zh": "实景与服务细节", "en": "实景与服务细节" },
  "case-004.505": { "zh": "图文沉浸，见证每一个精彩瞬间", "en": "图文沉浸，见证每一个精彩瞬间" },
  "case-004.523": { "zh": "核心服务亮点", "en": "核心服务亮点" },
  "case-004.524": { "zh": "差异化能力，打造独一无二的海上传奇", "en": "差异化能力，打造独一无二的海上传奇" },
  "case-004.528": { "zh": "🧊 Ice1A冰级船体认证", "en": "🧊 Ice1A冰级船体认证" },
  "case-004.530": { "zh": "船体结构通过DNV GL Ice1A认证，可安全航行于浮冰密集海域。配备冰区导航雷达与抗冰涂层，南极与阿拉斯加航线全覆盖。", "en": "船体结构通过DNV GL Ice1A认证，可安全航行于浮冰密集海域。配备冰区导航雷达与抗冰涂层，南极与阿拉斯加航线全覆盖。" },
  "case-004.534": { "zh": "☀️ 太阳能混合动力", "en": "☀️ 太阳能Hybrid" },
  "case-004.536": { "zh": "船顶配备200㎡高效太阳能电池阵列，配合锂电池储能系统。静音航行模式下可实现零排放，最大续航力达8,000海里。", "en": "船顶配备200㎡高效太阳能电池阵列，配合锂电池储能系统。静音航行模式下可实现零排放，最大续航力达8,000nm。" },
  "case-004.540": { "zh": "🔬 科研设备平台", "en": "🔬 科研设备平台" },
  "case-004.542": { "zh": "标准化科研设备接口，支持水质取样、水下摄影、气象观测等科考作业。配备卫星通讯系统，实现极地远程数据传输。", "en": "标准化科研设备接口，支持水质取样、水下摄影、气象观测等科考作业。配备卫星通讯系统，实现极地远程数据传输。" },
  "case-004.546": { "zh": "🚁 直升机停机坪", "en": "🚁 直升机停机坪" },
  "case-004.548": { "zh": "配备专业直升机停机坪，支持中型直升机起降。可用于冰上科考投放、紧急救援、物资补给等多场景。", "en": "配备专业直升机停机坪，支持中型直升机起降。可用于冰上科考投放、紧急救援、物资补给等多场景。" },
  "case-004.552": { "zh": "🌡️ 极地生存系统", "en": "🌡️ 极地生存系统" },
  "case-004.554": { "zh": "全船极地保暖系统，室内温度可达25℃。配备极地救生艇、防寒装备库、医疗急救站，通过极地航行安全认证。", "en": "全船极地保暖系统，室内温度可达25℃。配备极地救生艇、防寒装备库、医疗急救站，通过极地航行安全认证。" },
  "case-004.558": { "zh": "🌿 Green Yacht Award提名", "en": "🌿 Green Yacht Award提名" },
  "case-004.560": { "zh": "凭借太阳能混合动力系统与环保设计理念，获2024年Green Yacht Award提名。是极地探险游艇的环保标杆项目。", "en": "凭借太阳能Hybrid系统与环保设计理念，获2024年Green Yacht Award提名。是极地探险Yacht的环保标杆项目。" },
