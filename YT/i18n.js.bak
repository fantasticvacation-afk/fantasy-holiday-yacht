function applyI18n(lang) {
  try {
    if (typeof dict === 'undefined') {
      console.error('i18n Error: dict is not defined');
      return;
    }
    document.querySelectorAll('[data-i18n]').forEach(function(el) {
      var key = el.getAttribute('data-i18n');
      if (key && dict[key] && dict[key][lang]) {
        el.textContent = dict[key][lang];
      }
    });
  } catch(e) {
    console.error('i18n Error in applyI18n:', e);
  }
}

function switchLang(lang) {
  if (lang !== 'zh' && lang !== 'en') lang = 'zh';
  try { localStorage.setItem('fv-lang', lang); } catch(e){}
  applyI18n(lang);
  var btn = document.getElementById('langSwitchBtn');
  if (btn) btn.textContent = lang === 'zh' ? 'EN' : '中文';
}

(function initI18n() {
  var saved = 'zh';
  try { saved = localStorage.getItem('fv-lang') || 'zh'; } catch(e){}
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() { switchLang(saved); });
  } else {
    switchLang(saved);
  }
  var btn = document.getElementById('langSwitchBtn');
  if (btn) {
    btn.addEventListener('click', function() {
      var cur = 'zh';
      try { cur = localStorage.getItem('fv-lang') || 'zh'; } catch(e){}
      switchLang(cur === 'zh' ? 'en' : 'zh');
    });
  }
})();
