  "case-008.309": { "zh": "3艘VIP船提供赞助商与贵宾观赛接待，配备高档餐饮与观景甲板。", "en": "3艘VIP船提供赞助商与贵宾观赛接待，配备高档餐饮与观景甲板。" },
