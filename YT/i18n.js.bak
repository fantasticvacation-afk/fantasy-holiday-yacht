  "management.264": { "zh": "Yacht Management &amp; Maintenance", "en": "Yacht Management &amp; Maintenance" },
  "management.266": { "zh": "托管 · 维保 · 管家", "en": "托管 · 维保 · 管家" },
  "management.268": { "zh": "奇幻假期fantastic.vacation为您的海上资产提供全生命周期管家式托管服务", "en": "Fantastic Vacationfantastic.vacation为您的海上资产提供全生命周期管家式托管服务" },
