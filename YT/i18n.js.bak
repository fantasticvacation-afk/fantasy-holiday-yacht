  "charter.1039": { "zh": "适合远洋旅行 · 多岛联游", "en": "适合远洋旅行 · 多岛联游" },
  "charter.1041": { "zh": "远征系列具备强劲续航与稳定性，适合跨海域长距离航行，多目的地组合航线，探索传统小船无法抵达的秘境。", "en": "Expedition Series具备强劲续航与稳定性，适合跨海域长距离航行，多目的地组合航线，探索传统小船无法抵达的秘境。" },
  "charter.1044": { "zh": "马尔代夫", "en": "马尔代夫" },
  "charter.1045": { "zh": "希腊群岛", "en": "希腊群岛" },
  "charter.1046": { "zh": "挪威峡湾", "en": "挪威峡湾" },
  "charter.1047": { "zh": "大溪地", "en": "大溪地" },
  "charter.1054": { "zh": "君临系列 60-120M", "en": "Monarch Series 60-120M" },
  "charter.1056": { "zh": "适合奢华派对 · 企业接待", "en": "适合奢华派对 · 企业接待" },
  "charter.1058": { "zh": "超级游艇级别的规模与配置，直升机坪、游泳池、IMAX影院一应俱全，是全球顶级奢华活动的终极选择。", "en": "SuperYacht级别的规模与配置，直升机坪、游泳池、IMAX影院一应俱全，是全球顶级奢华活动的终极选择。" },
  "charter.1061": { "zh": "戛纳摩纳哥", "en": "戛纳摩纳哥" },
  "charter.1062": { "zh": "塞舌尔", "en": "塞舌尔" },
  "charter.1063": { "zh": "商务接待", "en": "商务接待" },
  "charter.1064": { "zh": "品牌活动", "en": "品牌活动" },
  "charter.1076": { "zh": "真实客户行程体验", "en": "真实客户行程体验" },
  "charter.1079": { "zh": "来自全球各地的真实旅行者分享他们的海上之旅，每一段故事都是对奇幻假期服务最好的背书", "en": "来自全球各地的真实旅行者分享他们的海上之旅，每一段故事都是对Fantastic Vacation服务最好的背书" },
  "charter.1085": { "zh": "★★★★★", "en": "★★★★★" },
  "charter.1087": { "zh": "第一次体验游艇租赁，选择了马尔代夫7天航线。超出预期太多！管家服务细致到每一个细节，连我太太喜欢喝的花茶都提前备好。下次一定再来。", "en": "第一次体验YachtCharter，选择了马尔代夫7天航线。超出预期太多！管家服务细致到每一个细节，连我太太喜欢喝的花茶都提前备好。下次一定再来。" },
  "charter.1089": { "zh": "李先生 &amp; 王女士", "en": "李先生 &amp; 王女士" },
  "charter.1091": { "zh": "马尔代夫环礁私密之旅 · 2026年2月", "en": "马尔代夫环礁私密之旅 · 2026年2月" },
  "charter.1096": { "zh": "★★★★★", "en": "★★★★★" },
  "charter.1098": { "zh": "为庆祝结婚10周年，带全家去了地中海法意经典环线。船长对每个停靠点了如指掌，孩子在船上玩得比在家还开心。最赞的是性价比，是市面价格的零头！", "en": "为庆祝结婚10周年，带全家去了Mediterranean法意经典环线。船长对每个停靠点了如指掌，孩子在船上玩得比在家还开心。最赞的是性价比，是市面Price的零头！" },
  "charter.1100": { "zh": "陈先生全家", "en": "陈先生全家" },
  "charter.1102": { "zh": "地中海法意经典环线 · 2025年9月", "en": "Mediterranean法意经典环线 · 2025年9月" },
  "charter.1107": { "zh": "★★★★★", "en": "★★★★★" },
  "charter.1109": { "zh": "和几个朋友租了飞桥系列去科莫多。船长带我们去了一个根本没有名字的私人沙滩，只有我们的游艇在那里。那种感觉无法用语言形容，绝对是人生最佳体验之一。", "en": "和几个朋友租了Flybridge Series去科莫多。船长带我们去了一个根本没有名字的私人沙滩，只有我们的Yacht在那里。那种感觉无法用语言形容，绝对是人生最佳体验之一。" },
  "charter.1111": { "zh": "张先生朋友圈", "en": "张先生朋友圈" },
  "charter.1113": { "zh": "巴厘岛科莫多探秘 · 2025年12月", "en": "巴厘岛科莫多探秘 · 2025年12月" },
  "charter.1124": { "zh": "租赁保障与合规承诺", "en": "Charter保障与合规承诺" },
  "charter.1126": { "zh": "您的安全与权益是我们的首要责任——每一项承诺都有制度保障，绝非空话", "en": "您的安全与权益是我们的首要责任——每一项承诺都有制度保障，绝非空话" },
  "charter.1130": { "zh": "🛡️", "en": "🛡️" },
  "charter.1131": { "zh": "船级社认证", "en": "船级社认证" },
  "charter.1132": { "zh": "所有船型均通过国际船级社认证，定期安全检测，证书齐全，航行安全有据可查", "en": "所有船型均通过国际船级社认证，定期安全检测，证书齐全，航行安全有据可查" },
  "charter.1135": { "zh": "全面保险", "en": "全面保险" },
  "charter.1136": { "zh": "船舶险、旅客险、第三方责任险全覆盖，行程中任何意外均有完善保障体系", "en": "船舶险、旅客险、第三方责任险全覆盖，行程中任何意外均有完善保障体系" },
  "charter.1139": { "zh": "无隐形消费", "en": "无隐形消费" },
  "charter.1140": { "zh": "报价包含所有标准服务，报价单透明公开，任何额外费用提前说明，绝无隐性消费陷阱", "en": "报价包含所有标准服务，报价单透明公开，任何额外费用提前说明，绝无隐性消费陷阱" },
  "charter.1143": { "zh": "行程保障", "en": "行程保障" },
  "charter.1144": { "zh": "因天气等不可抗力导致航线调整，团队全程协调，绝不让您承担额外损失", "en": "因天气等不可抗力导致航线调整，团队全程协调，绝不让您承担额外损失" },
  "charter.1155": { "zh": "开启您的专属航线", "en": "开启您的专属航线" },
  "charter.1157": { "zh": "从一通电话开始，让奇幻假期的专业航线规划团队为您量身定制独一无二的海上旅程。无论您想要浪漫的蜜月航线、家庭冒险之旅，还是商务接待的奢华排场——我们都能让您的梦想成真。", "en": "从一通Tel开始，让Fantastic Vacation的专业航线规划团队为您量身Custom独一无二的海上旅程。无论您想要浪漫的蜜月航线、家庭冒险之旅，还是商务接待的奢华排场——我们都能让您的梦想成真。" },
