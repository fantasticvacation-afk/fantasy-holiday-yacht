  "privacy.251": { "zh": "奇幻假期实业有限公司深知个人信息对您的重要性，我们将按照法律法规规定，保护您的个人信息及隐私安全。", "en": "Fantastic Vacation实业有限公司深知个人信息对您的重要性，我们将按照法律法规规定，保护您的个人信息及隐私安全。" },
  "privacy.252": { "zh": "我们收集的信息包括：您的姓名、联系方式、咨询偏好及浏览数据。这些信息仅用于为您提供更好的服务体验。", "en": "我们收集的信息包括：Your Name、联系方式、咨询偏好及浏览数据。这些信息仅用于为您提供更好的服务体验。" },
  "privacy.253": { "zh": "我们不会向任何第三方出售、出租或共享您的个人信息，除非获得您的明确同意或法律法规要求。", "en": "我们不会向任何第三方出售、出租或共享您的个人信息，除非获得您的明确同意或法律法规要求。" },
  "privacy.255": { "zh": "本隐私政策最后更新于2025年1月1日。", "en": "本Privacy Policy最后更新于2025年1月1日。" },
