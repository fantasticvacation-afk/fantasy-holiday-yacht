  "about-intro.6": { "zh": "公司简介 | 奇幻假期", "en": "Company Profile | Fantastic Vacation" },
  "about-intro.24": { "zh": "奇幻假期", "en": "Fantastic Vacation" },
  "about-intro.25": { "zh": "FANTASTIC VACATION", "en": "FANTASTIC VACATION" },
  "about-intro.38": { "zh": "关于我们", "en": "About Us" },
  "about-intro.58": { "zh": "业务板块", "en": "业务板块" },
  "about-intro.74": { "zh": "产品与服务", "en": "Products & Services" },
  "about-intro.92": { "zh": "新闻中心", "en": "News Center" },
  "about-intro.108": { "zh": "投资者关系", "en": "Investor Relations" },
  "about-intro.134": { "zh": "EN", "en": "EN" },
  "about-intro.155": { "zh": "公司简介", "en": "Company Profile" },
  "about-intro.157": { "zh": "全球顶级游艇定制与海上生活服务商", "en": "全球顶级YachtCustom与海上生活服务商" },
  "about-intro.163": { "zh": "品牌定位与行业地位", "en": "品牌定位与行业地位" },
  "about-intro.165": { "zh": "奇幻假期（Fantastic Vacation）是中国领先的豪华游艇定制与海上生活服务商，致力于为高端客群打造世界级的游艇体验。公司汇聚全球顶尖游艇制造商资源，提供从定制设计、租赁航线到托管维保的全方位服务。", "en": "Fantastic Vacation（Fantastic Vacation）是中国领先的LuxuryYachtCustom与海上生活服务商，致力于为高端客群打造世界级的Yacht体验。公司汇聚全球顶尖Yacht制造商资源，提供从Custom设计、Charter Routes到Management & Maintenance的全方位服务。" },
  "about-intro.167": { "zh": "作为Ferretti集团中国区独家战略合作伙伴、Feadship技术合作方，公司已成为中国高端游艇市场的行业标杆。", "en": "作为Ferretti集团中国区独家战略合作伙伴、Feadship技术合作方，公司已成为中国高端Yacht市场的行业标杆。" },
  "about-intro.172": { "zh": "50+", "en": "50+" },
  "about-intro.173": { "zh": "全球服务港口", "en": "全球服务港口" },
  "about-intro.175": { "zh": "128", "en": "128" },
  "about-intro.176": { "zh": "年度交付量", "en": "年度交付量" },
  "about-intro.178": { "zh": "98%", "en": "98%" },
  "about-intro.179": { "zh": "客户满意度", "en": "客户满意度" },
  "about-intro.181": { "zh": "200+", "en": "200+" },
  "about-intro.182": { "zh": "专业团队", "en": "专业团队" },
  "about-intro.190": { "zh": "核心业务全景", "en": "核心业务全景" },
  "about-intro.193": { "zh": "🎯 全案定制", "en": "🎯 Full Customization" },
  "about-intro.194": { "zh": "联合Ferretti、Feadship、Lürssen等顶级船厂，为客户量身定制50-120米超级游艇，涵盖外观设计、内饰装修、功能规划等全流程服务。", "en": "联合Ferretti、Feadship、Lürssen等顶级Shipyard，为客户量身Custom50-120米SuperYacht，涵盖外观设计、内饰装修、功能规划等全流程服务。" },
  "about-intro.196": { "zh": "⛵ 租赁航线", "en": "⛵ Charter Routes" },
  "about-intro.197": { "zh": "覆盖地中海、加勒比海、东南亚等20+热门海域，提供专业船长与船员服务，打造专属海上假期体验。", "en": "覆盖Mediterranean、Caribbean、Southeast Asia等20+Popular海域，提供专业船长与船员服务，打造专属海上假期体验。" },
  "about-intro.199": { "zh": "🔧 托管维保", "en": "🔧 Management & Maintenance" },
  "about-intro.200": { "zh": "提供游艇日常运营管理、定期保养、应急维修、海事合规代办等一站式托管服务，让客户无后顾之忧。", "en": "提供Yacht日常运营管理、定期保养、应急维修、海事合规代办等一站式托管服务，让客户无后顾之忧。" },
  "about-intro.202": { "zh": "🌐 全球服务网络", "en": "🌐 全球服务网络" },
  "about-intro.203": { "zh": "在香港、新加坡、东京、摩纳哥等地设有办事处，与全球50+优质码头建立战略合作。", "en": "在香港、新加坡、东京、摩纳哥等地设有办事处，与全球50+优质码头建立战略合作。" },
  "about-intro.210": { "zh": "全球服务网络", "en": "全球服务网络" },
